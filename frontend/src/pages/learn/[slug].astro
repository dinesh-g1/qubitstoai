---
export const prerender = false;
import Base from '../../layouts/Base.astro';
const slug = Astro.params.slug;
const API = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
let track: any = null, sections: any[] = [], lessons: any[] = [];
try {
  const [tr, sc, ls] = await Promise.all([
    fetch(`${API}/api/v1/tracks/${slug}`).then(r => r.ok ? r.json() : null),
    fetch(`${API}/api/v1/tracks/${slug}/sections`).then(r => r.ok ? r.json() : []),
    fetch(`${API}/api/v1/tracks/${slug}/lessons`).then(r => r.ok ? r.json() : []),
  ]);
  track = tr; sections = sc; lessons = ls;
} catch {}
const colors: Record<string,string> = {
  hardware:'var(--c-hardware)',systems:'var(--c-systems)',compilers:'var(--c-compilers)',
  web:'var(--c-web)',ml:'var(--c-ml)',agents:'var(--c-agents)'
};
const color = colors[slug as string] ?? 'var(--accent)';
---
<Base title={track ? `${track.title} — qubitstoai` : 'Not found'}>
  <div style="max-width:52rem;margin:0 auto;padding:3.5rem 1.5rem 6rem;">
    {!track ? (
      <p style="color:var(--foreground-3);font-size:0.875rem;">Not found. <a href="/learn" style="color:var(--accent);">← Back</a></p>
    ) : (
      <>
        <a href="/learn" style="display:inline-flex;align-items:center;gap:5px;font-size:0.8rem;color:var(--foreground-3);margin-bottom:2rem;transition:color 0.1s;" onmouseover="this.style.color='var(--foreground)'" onmouseout="this.style.color='var(--foreground-3)'">
          <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 17l-5-5m0 0l5-5m-5 5h12"/></svg>
          All topics
        </a>
        <div style="display:flex;align-items:flex-start;gap:1rem;margin-bottom:2.5rem;padding-bottom:1.75rem;border-bottom:1px solid var(--border);">
          <div style={`width:40px;height:40px;border-radius:var(--radius-sm);display:flex;align-items:center;justify-content:center;font-family:var(--font-mono);font-size:0.875rem;font-weight:500;flex-shrink:0;background:color-mix(in srgb,${color} 12%,var(--background-2));color:${color}`}>{(slug as string).charAt(0).toUpperCase()}</div>
          <div>
            <h1 style="font-size:1.5rem;font-weight:700;letter-spacing:-0.02em;color:var(--foreground);margin-bottom:0.3rem;">{track.title}</h1>
            <p style="font-size:0.875rem;color:var(--foreground-3);">{track.description}</p>
          </div>
        </div>
        {sections.length > 0 ? (
          <div style="display:flex;flex-direction:column;gap:0.5rem;">
            {sections.map((section: any) => (
              <a href={`/learn/${slug}/${section.slug}`} style="display:flex;align-items:center;justify-content:space-between;gap:1rem;padding:1.25rem 1.25rem;background:var(--background-1);border:1px solid var(--border);border-radius:var(--radius-lg);text-decoration:none;transition:background 0.1s,border-color 0.1s;" onmouseover="this.style.background='var(--background-2)';this.style.borderColor='var(--background-3)'" onmouseout="this.style.background='var(--background-1)';this.style.borderColor='var(--border)'">
                <div>
                  <div style="font-size:0.9375rem;font-weight:500;color:var(--foreground);margin-bottom:0.3rem;">{section.title}</div>
                  <div style="font-size:0.8rem;color:var(--foreground-4);line-height:1.5;">{section.description}</div>
                </div>
                <div style="display:flex;align-items:center;gap:0.75rem;flex-shrink:0;">
                  {section.post_count > 0 && <span style="font-family:var(--font-mono);font-size:0.7rem;color:var(--foreground-4);">{section.post_count} article{section.post_count!==1?'s':''}</span>}
                  <svg width="14" height="14" fill="none" stroke="var(--foreground-4)" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                </div>
              </a>
            ))}
          </div>
        ) : lessons.length > 0 ? (
          <div>
            {lessons.map((lesson: any) => (
              <a href={`/learn/${slug}/${lesson.slug}`} style="display:flex;align-items:center;gap:1rem;padding:0.9rem 0.75rem;border-radius:var(--radius);transition:background 0.1s;text-decoration:none;" onmouseover="this.style.background='var(--background-2)'" onmouseout="this.style.background='transparent'">
                <span style="font-family:var(--font-mono);font-size:0.7rem;color:var(--foreground-4);width:24px;flex-shrink:0;">{String(lesson.sort_order).padStart(2,'0')}</span>
                <div style="flex:1;">
                  <div style="font-size:0.9375rem;font-weight:500;color:var(--foreground);">{lesson.title}</div>
                  <div style="font-size:0.8rem;color:var(--foreground-4);margin-top:0.2rem;">{lesson.description}</div>
                </div>
                <span style="font-family:var(--font-mono);font-size:0.7rem;color:var(--foreground-4);">{lesson.read_mins}m</span>
              </a>
            ))}
          </div>
        ) : (
          <div style="border:1px dashed var(--border);border-radius:var(--radius-lg);padding:3rem;text-align:center;">
            <div style="font-family:var(--font-mono);font-size:0.7rem;color:var(--foreground-4);margin-bottom:0.4rem;">// coming soon</div>
            <p style="font-size:0.875rem;color:var(--foreground-3);">Content is being written. <a href="/#newsletter" style="color:var(--accent);">Subscribe →</a></p>
          </div>
        )}
      </>
    )}
  </div>
</Base>
