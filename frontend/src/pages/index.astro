---
import Base from '../layouts/Base.astro';
const API = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
const tracks = [
  { slug:'hardware',  title:'Hardware',          sub:'NAND gates → CPU',            dot:'var(--c-hw)' },
  { slug:'systems',   title:'Systems',            sub:'Assembly → OS internals',     dot:'var(--c-sy)' },
  { slug:'compilers', title:'Compilers & VMs',    sub:'Lexers → bytecode',           dot:'var(--c-co)' },
  { slug:'web',       title:'Web & Backend',      sub:'HTTP → full-stack',           dot:'var(--c-wb)' },
  { slug:'ml',        title:'ML & Deep Learning', sub:'Math → transformers',         dot:'var(--c-ml)' },
  { slug:'agents',    title:'AI Agents',          sub:'Planning → autonomy',         dot:'var(--c-ag)' },
];
let posts: any[] = [];
try { const r = await fetch(`${API}/api/v1/posts`); if (r.ok) posts = await r.json(); } catch {}
---
<Base>
<style>
  .w  { max-width: 72rem; margin: 0 auto; padding: 0 1.5rem; }

  /* Hero */
  .hero { padding: 5rem 0 4rem; border-bottom: 1px solid var(--border); }
  .hero-pill {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 0.65rem; color: var(--fg-4); border: 1px solid var(--border);
    padding: 3px 10px; margin-bottom: 2rem;
  }
  .hero-pill-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--fg-4); animation: blink 2s infinite; }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.15} }
  .hero h1 {
    font-size: clamp(1.875rem, 5vw, 3.25rem); font-weight: 700;
    line-height: 1.08; letter-spacing: -0.02em; color: var(--fg);
    margin-bottom: 1.125rem; max-width: 580px;
  }
  .hero-sub { font-size: 0.8125rem; color: var(--fg-3); line-height: 1.75; max-width: 420px; margin-bottom: 2rem; }
  .hero-btns { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 3.5rem; }
  .hero-stats { display: flex; flex-wrap: wrap; gap: 2.5rem; padding-top: 1.75rem; border-top: 1px solid var(--border); }
  .stat-v { font-size: 1.25rem; font-weight: 700; color: var(--fg); }
  .stat-l { font-size: 0.65rem; color: var(--fg-4); display: block; margin-top: 1px; }

  /* Section */
  .sec { padding: 3rem 0; border-bottom: 1px solid var(--border); }
  .sec-hdr { display: flex; align-items: flex-end; justify-content: space-between; gap: 1rem; flex-wrap: wrap; margin-bottom: 1.25rem; }
  .sec-label { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--fg-4); margin-bottom: 0.25rem; }
  .sec-title { font-size: 0.875rem; font-weight: 600; color: var(--fg); }

  /* Track grid — 3 col with 1px border gaps, zero radius, like the screenshot */
  .tracks-grid {
    display: grid; grid-template-columns: repeat(3,1fr);
    border: 1px solid var(--border); overflow: hidden;
  }
  .track-card {
    padding: 1.125rem; background: var(--background);
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    transition: background 0.1s; text-decoration: none;
    display: block;
  }
  .track-card:nth-child(3n) { border-right: none; }
  .track-card:nth-child(n+4) { border-bottom: none; }
  .track-card:hover { background: var(--bg-hover); }
  .track-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.6rem; }
  .track-idx { font-size: 0.6rem; color: var(--fg-4); }
  .track-dot { width: 6px; height: 6px; border-radius: 50%; }
  .track-name { font-size: 0.8125rem; font-weight: 600; color: var(--fg); margin-bottom: 0.25rem; }
  .track-sub  { font-size: 0.7rem; color: var(--fg-4); line-height: 1.5; }

  /* Post rows */
  .post-row {
    display: flex; align-items: flex-start; gap: 0.875rem;
    padding: 0.75rem 0.625rem; transition: background 0.1s; text-decoration: none;
  }
  .post-row:hover { background: var(--bg-hover); }
  .post-i  { font-size: 0.6rem; color: var(--fg-4); width: 16px; flex-shrink: 0; padding-top: 2px; }
  .post-tg { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--fg-4); margin-bottom: 0.15rem; }
  .post-ti { font-size: 0.8125rem; font-weight: 500; color: var(--fg); line-height: 1.4; }
  .post-me { font-size: 0.6rem; color: var(--fg-4); margin-top: 0.2rem; }

  /* Newsletter — left aligned, fused input+button */
  .nl-sec { padding: 3.5rem 0; }
  .nl-box { max-width: 380px; }
  .nl-label { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--fg-4); margin-bottom: 0.3rem; }
  .nl-title { font-size: 1rem; font-weight: 700; color: var(--fg); margin-bottom: 0.35rem; }
  .nl-sub   { font-size: 0.75rem; color: var(--fg-3); line-height: 1.65; margin-bottom: 1.125rem; }
  .nl-form  {
    display: flex; border: 1px solid var(--border-input); overflow: hidden;
  }
  .nl-form .input {
    border: none; border-radius: 0; flex: 1; background: var(--bg-card);
    font-size: 0.75rem;
  }
  .nl-form .input:focus { box-shadow: none; border: none; }
  .nl-form-btn {
    border: none; border-left: 1px solid var(--border-input);
    background: var(--primary); color: var(--primary-fg);
    font-family: var(--font); font-size: 0.75rem; font-weight: 500;
    padding: 0 14px; cursor: pointer; transition: background 0.1s; white-space: nowrap;
  }
  .nl-form-btn:hover { background: #e4e4e4; }
  .nl-msg { font-size: 0.7rem; color: var(--fg-3); margin-top: 0.5rem; display: none; }

  /* Empty */
  .empty { padding: 2.5rem; border: 1px dashed var(--border); text-align: center; }
  .empty-code { font-size: 0.65rem; color: var(--fg-4); margin-bottom: 0.35rem; }
  .empty p { font-size: 0.75rem; color: var(--fg-3); }

  @media (max-width: 640px) { .tracks-grid { grid-template-columns: 1fr 1fr; } .track-card:nth-child(2n) { border-right: none; } .track-card:nth-child(3n) { border-right: 1px solid var(--border); } }
  @media (max-width: 400px) { .tracks-grid { grid-template-columns: 1fr; } }
</style>

<!-- Hero -->
<section><div class="w">
  <div class="hero">
    <div class="hero-pill"><span class="hero-pill-dot"></span>building in public</div>
    <h1>Computer science,<br/>from the ground up.</h1>
    <p class="hero-sub">From a single NAND gate to autonomous AI agents. Every layer explained, every concept built from scratch.</p>
    <div class="hero-btns">
      <a href="/learn" class="btn btn-primary">
        start exploring
        <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </a>
      <a href="/blog" class="btn btn-outline">read the blog</a>
    </div>
    <div class="hero-stats">
      <div><span class="stat-v">6</span><span class="stat-l">topics</span></div>
      <div><span class="stat-v">120+</span><span class="stat-l">planned articles</span></div>
      <div><span class="stat-v">free</span><span class="stat-l">forever</span></div>
    </div>
  </div>
</div></section>

<!-- Topics -->
<section class="sec"><div class="w">
  <div class="sec-hdr">
    <div><div class="sec-label">exploring</div><div class="sec-title">Topics I'm diving into</div></div>
    <a href="/learn" class="btn btn-ghost btn-sm">view all <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg></a>
  </div>
  <div class="tracks-grid">
    {tracks.map((t, i) => (
      <a href={`/learn/${t.slug}`} class="track-card">
        <div class="track-row">
          <span class="track-idx">{String(i+1).padStart(2,'0')}</span>
          <span class="track-dot" style={`background:${t.dot}`}></span>
        </div>
        <div class="track-name">{t.title}</div>
        <div class="track-sub">{t.sub}</div>
      </a>
    ))}
  </div>
</div></section>

<!-- Posts -->
<section class="sec"><div class="w">
  <div class="sec-hdr">
    <div><div class="sec-label">latest</div><div class="sec-title">Recent articles</div></div>
    <a href="/blog" class="btn btn-ghost btn-sm">all articles <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg></a>
  </div>
  {posts.length > 0 ? (
    <div>
      {posts.slice(0,5).map((p: any, i: number) => (
        <a href={`/blog/${p.slug}`} class="post-row">
          <span class="post-i">{String(i+1).padStart(2,'0')}</span>
          <div style="flex:1">
            <div class="post-tg">{p.tag}</div>
            <div class="post-ti">{p.title}</div>
            <div class="post-me">{p.read_mins} min read</div>
          </div>
          <svg width="12" height="12" fill="none" stroke="var(--fg-4)" stroke-width="1.5" viewBox="0 0 24 24" style="flex-shrink:0;margin-top:3px"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
      ))}
    </div>
  ) : (
    <div class="empty">
      <div class="empty-code">// coming soon</div>
      <p>First articles dropping soon.</p>
    </div>
  )}
</div></section>

<!-- Newsletter — left aligned, fused input -->
<section class="nl-sec" id="newsletter"><div class="w">
  <div class="nl-box">
    <div class="nl-label">newsletter</div>
    <div class="nl-title">Follow the build</div>
    <p class="nl-sub">What I learned, what I built, what broke. No spam.</p>
    <form id="nl-form" class="nl-form">
      <input type="email" id="nl-email" placeholder="you@email.com" required class="input" />
      <button type="submit" class="nl-form-btn">Subscribe</button>
    </form>
    <p id="nl-msg" class="nl-msg"></p>
  </div>
</div></section>

<script>
  const form = document.getElementById('nl-form') as HTMLFormElement;
  const msg  = document.getElementById('nl-msg')  as HTMLElement;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (document.getElementById('nl-email') as HTMLInputElement).value;
    try {
      const res = await fetch('/api/v1/newsletter/subscribe', {
        method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({email}),
      });
      msg.textContent = res.ok ? '✓ subscribed!' : 'something went wrong.';
      msg.style.color = res.ok ? 'var(--success)' : 'var(--danger)';
      msg.style.display = 'block';
      if (res.ok) form.reset();
    } catch { msg.textContent = 'network error.'; msg.style.display = 'block'; }
  });
</script>
</Base>
