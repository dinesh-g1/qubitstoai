---
export const prerender = false;
import Base from '../../layouts/Base.astro';
const { slug } = Astro.params;
const API = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
let post: any = null;
try {
  const res = await fetch(`${API}/api/v1/posts/${slug}`);
  if (res.ok) post = await res.json();
} catch {}
---
<Base title={post ? `${post.title} — qubitstoai` : 'Not found'} description={post?.description}>
  {!post ? (
    <div style="max-width:48rem;margin:0 auto;padding:6rem 1.5rem;text-align:center;">
      <div style="font-family:var(--font-mono);font-size:0.7rem;color:var(--foreground-4);margin-bottom:0.5rem;">404</div>
      <p style="color:var(--foreground-3);font-size:0.875rem;">Post not found. <a href="/blog" style="color:var(--accent);">Back to blog →</a></p>
    </div>
  ) : (
    <div style="max-width:46rem;margin:0 auto;padding:3rem 1.5rem 6rem;">
      <a href="/blog" style="display:inline-flex;align-items:center;gap:5px;font-size:0.8rem;color:var(--foreground-3);margin-bottom:2.5rem;transition:color 0.1s;" onmouseover="this.style.color='var(--foreground)'" onmouseout="this.style.color='var(--foreground-3)'">
        <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 17l-5-5m0 0l5-5m-5 5h12"/></svg>
        Blog
      </a>
      <header style="margin-bottom:2.5rem;padding-bottom:1.75rem;border-bottom:1px solid var(--border);">
        <div style="margin-bottom:1rem;">
          <span style="font-family:var(--font-mono);font-size:0.65rem;text-transform:uppercase;letter-spacing:0.08em;background:var(--accent-subtle);color:var(--accent-hover);padding:3px 8px;border-radius:var(--radius-sm);border:1px solid var(--accent-border);">{post.tag}</span>
        </div>
        <h1 style="font-size:clamp(1.5rem,3.5vw,2.25rem);font-weight:700;letter-spacing:-0.02em;color:var(--foreground);line-height:1.2;margin-bottom:0.85rem;">{post.title}</h1>
        {post.description && <p style="font-size:1rem;color:var(--foreground-3);line-height:1.6;">{post.description}</p>}
        <div style="display:flex;align-items:center;gap:1rem;margin-top:1rem;font-family:var(--font-mono);font-size:0.7rem;color:var(--foreground-4);">
          <span>{post.read_mins} min read</span>
          <span>·</span>
          <span>{new Date(post.created_at).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})}</span>
        </div>
      </header>
      {post.content ? (
        <article class="prose" set:html={post.content} />
      ) : (
        <div style="border:1px dashed var(--border);border-radius:var(--radius-lg);padding:3rem;text-align:center;">
          <div style="font-family:var(--font-mono);font-size:0.7rem;color:var(--foreground-4);margin-bottom:0.4rem;">// content coming soon</div>
        </div>
      )}
    </div>
  )}
</Base>
