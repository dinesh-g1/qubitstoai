---
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'qubitstoai — From NAND gates to AI agents',
  description = 'Deep, structured computer science from logic gates and circuits all the way to autonomous AI agents.',
} = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,600&family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    /* ── Reset ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }

    /* ── Design tokens ── */
    :root {
      /* Colors */
      --bg:           #FAFAF7;   /* warm paper white */
      --bg-card:      #FFFFFF;   /* pure white for cards */
      --bg-raised:    #F3F2EE;   /* slightly deeper for hover / sidebar */
      --border:       #E2E0DA;   /* warm grey dividers */
      --border-light: #ECEAE4;   /* very subtle */

      --ink:          #1C1917;   /* warm near-black for headlines */
      --ink-2:        #44403C;   /* secondary text */
      --ink-3:        #78716C;   /* muted — captions, meta */
      --ink-4:        #A8A29E;   /* very muted — placeholders */

      --blue:         #2563EB;   /* primary accent — links, CTAs */
      --blue-hover:   #1D4ED8;
      --blue-light:   #EFF6FF;   /* tinted bg behind blue elements */
      --blue-border:  #BFDBFE;

      /* Track accent colors — warm, not neon */
      --c-hardware:   #7C3AED;
      --c-systems:    #059669;
      --c-compilers:  #D97706;
      --c-web:        #2563EB;
      --c-ml:         #DC2626;
      --c-agents:     #16A34A;

      /* Typography */
      --font-body:    'Plus Jakarta Sans', system-ui, sans-serif;
      --font-display: 'Fraunces', Georgia, serif;
      --font-mono:    'JetBrains Mono', 'Fira Code', monospace;

      --text-xs:   0.78rem;
      --text-sm:   0.9375rem;
      --text-base: 1.0625rem;
      --text-lg:   1.1875rem;
      --text-xl:   1.375rem;
      --text-2xl:  1.75rem;
      --text-3xl:  2.25rem;
      --text-4xl:  3rem;
      --text-5xl:  3.75rem;
    }

    /* ── Base ── */
    body {
      font-family: var(--font-body);
      font-size: var(--text-base);
      line-height: 1.7;
      background: var(--bg);
      color: var(--ink-2);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    h1, h2, h3, h4, h5, h6 {
      font-family: var(--font-display);
      color: var(--ink);
      line-height: 1.15;
    }

    a { color: var(--blue); text-decoration: none; }
    a:hover { color: var(--blue-hover); }

    code, kbd, pre { font-family: var(--font-mono); }

    /* ── Nav ── */
    #nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 50;
      height: 62px;
      background: rgba(250, 250, 247, 0.92);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border-light);
      transition: border-color 0.2s;
    }
    .nav-inner {
      max-width: 72rem; margin: 0 auto; padding: 0 1.75rem;
      height: 100%; display: flex; align-items: center; justify-content: space-between;
    }
    .nav-logo {
      font-family: var(--font-display);
      font-size: 1.15rem; font-weight: 700;
      color: var(--ink); letter-spacing: -0.01em;
    }
    .nav-logo span { color: var(--blue); }
    .nav-links { display: flex; align-items: center; gap: 2rem; }
    .nav-links a {
      font-size: var(--text-sm); font-weight: 500;
      color: var(--ink-3);
      transition: color 0.15s;
    }
    .nav-links a:hover { color: var(--ink); }
    .nav-right { display: flex; align-items: center; gap: 0.75rem; }
    .nav-subscribe {
      font-size: var(--text-xs); font-weight: 600;
      padding: 7px 18px; border-radius: 999px;
      border: 1.5px solid var(--blue-border);
      color: var(--blue);
      background: var(--blue-light);
      transition: background 0.15s, border-color 0.15s;
    }
    .nav-subscribe:hover {
      background: #DBEAFE;
      border-color: #93C5FD;
      color: var(--blue-hover);
    }
    #mobile-menu {
      display: none;
      border-top: 1px solid var(--border);
      background: var(--bg);
    }
    #mobile-menu.open { display: block; }
    #mobile-menu .inner {
      max-width: 72rem; margin: 0 auto;
      padding: 1.25rem 1.75rem;
      display: flex; flex-direction: column; gap: 1rem;
    }
    #mobile-menu a {
      font-size: var(--text-base); font-weight: 500;
      color: var(--ink-3);
    }
    #mobile-menu a:hover { color: var(--ink); }

    /* ── Footer ── */
    footer {
      border-top: 1px solid var(--border);
      background: var(--bg-card);
      margin-top: 6rem;
    }
    .footer-grid {
      max-width: 72rem; margin: 0 auto;
      padding: 3.5rem 1.75rem;
      display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 2.5rem;
    }
    .footer-logo {
      font-family: var(--font-display);
      font-size: 1.1rem; font-weight: 700;
      color: var(--ink); margin-bottom: 0.75rem;
    }
    .footer-logo span { color: var(--blue); }
    .footer-desc {
      font-size: var(--text-sm); color: var(--ink-3);
      line-height: 1.75; max-width: 22rem;
    }
    .footer-heading {
      font-family: var(--font-mono);
      font-size: 0.68rem; text-transform: uppercase;
      letter-spacing: 0.12em; color: var(--ink-4);
      margin-bottom: 1rem;
    }
    .footer-links { display: flex; flex-direction: column; gap: 0.55rem; }
    .footer-links a {
      font-size: var(--text-sm); font-weight: 500;
      color: var(--ink-3); transition: color 0.15s;
    }
    .footer-links a:hover { color: var(--blue); }
    .footer-bottom {
      border-top: 1px solid var(--border);
    }
    .footer-bottom-inner {
      max-width: 72rem; margin: 0 auto;
      padding: 1rem 1.75rem;
      display: flex; justify-content: space-between;
      font-family: var(--font-mono); font-size: var(--text-xs);
      color: var(--ink-4);
    }

    /* ── Prose (articles) ── */
    .prose {
      font-family: var(--font-body);
      font-size: var(--text-base);
      line-height: 1.8;
      color: var(--ink-2);
    }
    .prose h1, .prose h2, .prose h3, .prose h4 {
      font-family: var(--font-display);
      color: var(--ink);
      margin-top: 2.25em; margin-bottom: 0.65em;
    }
    .prose h1 { font-size: var(--text-3xl); }
    .prose h2 { font-size: var(--text-2xl); border-bottom: 1px solid var(--border-light); padding-bottom: 0.4em; }
    .prose h3 { font-size: var(--text-xl); }
    .prose p  { margin-bottom: 1.35em; }
    .prose a  { color: var(--blue); text-decoration: underline; text-underline-offset: 3px; }
    .prose a:hover { color: var(--blue-hover); }
    .prose strong { color: var(--ink); font-weight: 600; }
    .prose em { font-style: italic; }
    .prose code {
      font-family: var(--font-mono); font-size: 0.875em;
      background: var(--bg-raised); color: var(--ink);
      padding: 2px 6px; border-radius: 4px;
      border: 1px solid var(--border);
    }
    .prose pre {
      background: #1E1E2E;
      border-radius: 10px; padding: 1.25rem 1.5rem;
      overflow-x: auto; margin: 1.75em 0;
      border: 1px solid #2D2D3F;
    }
    .prose pre code {
      background: none; border: none; padding: 0;
      color: #CDD6F4; font-size: 0.9rem;
    }
    .prose blockquote {
      border-left: 3px solid var(--blue-border);
      padding: 0.5em 1.25em; margin: 1.75em 0;
      color: var(--ink-3); font-style: italic;
      background: var(--blue-light); border-radius: 0 8px 8px 0;
    }
    .prose ul, .prose ol {
      margin: 1.25em 0 1.25em 1.5em; color: var(--ink-2);
    }
    .prose li { margin-bottom: 0.45em; }
    .prose hr {
      border: none; border-top: 1px solid var(--border);
      margin: 2.5em 0;
    }
    .prose img { border-radius: 10px; max-width: 100%; }
    .prose table { width: 100%; border-collapse: collapse; margin: 1.75em 0; font-size: var(--text-sm); }
    .prose th { background: var(--bg-raised); font-weight: 600; color: var(--ink); text-align: left; padding: 0.65em 1em; border: 1px solid var(--border); }
    .prose td { padding: 0.6em 1em; border: 1px solid var(--border); }

    /* ── Utilities ── */
    .label {
      font-family: var(--font-mono); font-size: 0.7rem;
      text-transform: uppercase; letter-spacing: 0.14em;
      color: var(--ink-4);
    }
    .section-title {
      font-family: var(--font-display);
      font-size: var(--text-3xl); font-weight: 700;
      color: var(--ink); letter-spacing: -0.02em;
    }
    .card {
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: 12px; transition: border-color 0.15s, box-shadow 0.15s;
    }
    .card:hover {
      border-color: #C7C3BB;
      box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    }
    .btn-primary {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 12px 24px; background: var(--blue); color: #fff;
      border-radius: 9px; font-weight: 600; font-size: var(--text-sm);
      transition: background 0.15s, transform 0.1s; border: none; cursor: pointer;
      font-family: var(--font-body);
    }
    .btn-primary:hover { background: var(--blue-hover); color: #fff; transform: translateY(-1px); }
    .btn-ghost {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 12px 24px; border: 1.5px solid var(--border);
      color: var(--ink-2); border-radius: 9px; font-weight: 600;
      font-size: var(--text-sm); transition: border-color 0.15s, color 0.15s;
      background: none; cursor: pointer; font-family: var(--font-body);
    }
    .btn-ghost:hover { border-color: var(--ink-3); color: var(--ink); }

    /* ── Responsive ── */
    @media (max-width: 768px) {
      .nav-links { display: none; }
      .nav-subscribe { display: none; }
      .footer-grid { grid-template-columns: 1fr; }
    }
    @media (min-width: 769px) { #menu-btn { display: none !important; } }
  </style>
</head>

<body>
  <!-- NAV -->
  <nav id="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">qubits<span>to</span>ai</a>
      <div class="nav-links">
        <a href="/learn">Learn</a>
        <a href="/blog">Blog</a>
        <a href="/projects">Projects</a>
        <a href="/about">About</a>
      </div>
      <div class="nav-right">
        <a href="#newsletter" class="nav-subscribe">Subscribe</a>
        <button id="menu-btn" style="background:none;border:none;cursor:pointer;padding:4px;color:var(--ink-3);display:none;" aria-label="menu">
          <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <path stroke-linecap="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <div id="mobile-menu">
    <div class="inner">
      <a href="/learn">Learn</a>
      <a href="/blog">Blog</a>
      <a href="/projects">Projects</a>
      <a href="/about">About</a>
    </div>
  </div>

  <main style="padding-top: 62px;">
    <slot />
  </main>

  <!-- FOOTER -->
  <footer>
    <div class="footer-grid">
      <div>
        <div class="footer-logo">qubits<span>to</span>ai</div>
        <p class="footer-desc">Computer science from the ground up. No shortcuts — deep understanding built layer by layer.</p>
      </div>
      <div>
        <div class="footer-heading">Explore</div>
        <div class="footer-links">
          <a href="/learn/hardware">Hardware</a>
          <a href="/learn/systems">Systems</a>
          <a href="/learn/compilers">Compilers</a>
          <a href="/learn/web">Web</a>
          <a href="/learn/ml">ML</a>
          <a href="/learn/agents">AI Agents</a>
        </div>
      </div>
      <div>
        <div class="footer-heading">Connect</div>
        <div class="footer-links">
          <a href="https://github.com/qubitstoai">GitHub</a>
          <a href="https://youtube.com/@qubitstoai">YouTube</a>
          <a href="https://x.com/qubitstoai">X / Twitter</a>
          <a href="/rss.xml">RSS</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="footer-bottom-inner">
        <span>© 2025 qubitstoai.com · Built in public</span>
        <span>From NAND gates to AI agents</span>
      </div>
    </div>
  </footer>

  <script>
    document.getElementById('menu-btn')?.addEventListener('click', () => {
      document.getElementById('mobile-menu')?.classList.toggle('open');
    });
  </script>
</body>
</html>
