---
import Base from '../../layouts/Base.astro';
const tracks = [
  { slug:'hardware',  title:'Hardware',          desc:'Qubits, quantum circuits, quantum hardware', dot:'var(--c-hw)' },
  { slug:'systems',   title:'Systems',            desc:'Assembly, C, OS internals, shells',      dot:'var(--c-sy)' },
  { slug:'compilers', title:'Compilers & VMs',    desc:'Lexers, parsers, bytecode, runtimes',    dot:'var(--c-co)' },
  { slug:'web',       title:'Web & Backend',      desc:'HTTP, databases, REST, system design',   dot:'var(--c-wb)' },
  { slug:'ml',        title:'ML & Deep Learning', desc:'Linear algebra, neural nets, LLMs',      dot:'var(--c-ml)' },
  { slug:'agents',    title:'AI Agents',          desc:'Planning, memory, tools, autonomy',      dot:'var(--c-ag)' },
];
---
<Base title="Learn — qubitstoai">
<div style="max-width:52rem;margin:0 auto;padding:3rem 1.5rem 6rem;">
  <div style="padding-bottom:1.5rem;border-bottom:1px solid var(--border);margin-bottom:1.25rem;">
    <div style="font-size:0.6rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--fg-4);margin-bottom:0.3rem;">exploring</div>
    <h1 style="font-size:1.5rem;font-weight:700;letter-spacing:-0.02em;color:var(--fg);">Topics I explore</h1>
    <p style="font-size:0.75rem;color:var(--fg-3);margin-top:0.35rem;max-width:380px;line-height:1.65;">Areas I find genuinely interesting — started from hardware because I wanted to understand how everything actually works.</p>
  </div>
  <div style="display:flex;flex-direction:column;gap:2px;">
    {tracks.map((t, i) => (
      <a href={`/learn/${t.slug}`} style="display:flex;align-items:center;gap:1rem;padding:0.875rem 1rem;border:1px solid var(--border);background:var(--bg-card);transition:background 0.1s;text-decoration:none;margin-bottom:0.375rem;" onmouseover="this.style.background='var(--bg-hover)'" onmouseout="this.style.background='var(--bg-card)'">
        <div style="display:flex;align-items:center;gap:0.625rem;flex-shrink:0;">
          <span style="font-size:0.6rem;color:var(--fg-4);width:18px;">{String(i+1).padStart(2,'0')}</span>
          <span style={`width:6px;height:6px;border-radius:50%;background:${t.dot};flex-shrink:0;`}></span>
        </div>
        <div style="flex:1;">
          <div style="font-size:0.8125rem;font-weight:600;color:var(--fg);margin-bottom:0.15rem;">{t.title}</div>
          <div style="font-size:0.7rem;color:var(--fg-4);">{t.desc}</div>
        </div>
        <svg width="12" height="12" fill="none" stroke="var(--fg-4)" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </a>
    ))}
  </div>
</div>
</Base>