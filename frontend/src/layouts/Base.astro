---
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'qubitstoai — From NAND gates to AI agents',
  description = 'Deep, structured computer science from logic gates and circuits all the way to autonomous AI agents.',
} = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    /* ── Dark theme (default) ── */
    :root, [data-theme="dark"] {
      --bg:        #09090b;
      --bg-card:   #18181b;
      --bg-hover:  #27272a;
      --border:    #27272a;
      --text:      #f4f4f5;
      --text-muted:#a1a1aa;
      --text-faint:#52525b;
      --brand:     #7F77DD;
      --brand-dim: #534AB7;
    }
    /* ── Light theme ── */
    [data-theme="light"] {
      --bg:        #fafafa;
      --bg-card:   #ffffff;
      --bg-hover:  #f4f4f5;
      --border:    #e4e4e7;
      --text:      #09090b;
      --text-muted:#52525b;
      --text-faint:#a1a1aa;
      --brand:     #534AB7;
      --brand-dim: #3C3489;
    }

    body           { background: var(--bg); color: var(--text); }
    .theme-border  { border-color: var(--border); }
    .theme-card    { background: var(--bg-card); }
    .theme-muted   { color: var(--text-muted); }
    .theme-faint   { color: var(--text-faint); }
    .theme-brand   { color: var(--brand); }

    /* Toggle switch */
    .toggle-track {
      width: 40px; height: 22px;
      background: var(--border);
      border-radius: 999px;
      position: relative;
      cursor: pointer;
      transition: background 0.2s;
      border: 1px solid var(--border);
      flex-shrink: 0;
    }
    [data-theme="light"] .toggle-track { background: var(--brand); }
    .toggle-thumb {
      width: 16px; height: 16px;
      background: var(--text);
      border-radius: 50%;
      position: absolute;
      top: 2px; left: 2px;
      transition: transform 0.2s, background 0.2s;
    }
    [data-theme="light"] .toggle-thumb { transform: translateX(18px); }
  </style>
  <!-- Apply saved theme before paint to avoid flash -->
  <script is:inline>
    const saved = localStorage.getItem('theme') || 'dark';
    document.documentElement.setAttribute('data-theme', saved);
  </script>
</head>
<body style="background: var(--bg); color: var(--text); font-family: 'DM Sans', system-ui, sans-serif;">

  <!-- NAV -->
  <nav id="nav" style="position:fixed;top:0;left:0;right:0;z-index:50;border-bottom:1px solid var(--border);background:color-mix(in srgb, var(--bg) 90%, transparent);backdrop-filter:blur(12px);transition:all 0.3s;">
    <div style="max-width:72rem;margin:0 auto;padding:0 1.5rem;display:flex;align-items:center;justify-content:space-between;height:56px;">

      <a href="/" style="font-family:'Syne',sans-serif;font-size:1rem;font-weight:700;text-decoration:none;color:var(--text);">
        qubits<span style="color:var(--brand);">to</span>ai
      </a>

      <div style="display:flex;align-items:center;gap:2rem;">
        <div style="display:flex;gap:2rem;font-size:0.875rem;color:var(--text-muted);" class="nav-links">
          <a href="/learn"    style="color:var(--text-muted);text-decoration:none;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">Learn</a>
          <a href="/blog"     style="color:var(--text-muted);text-decoration:none;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">Blog</a>
          <a href="/projects" style="color:var(--text-muted);text-decoration:none;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">Projects</a>
          <a href="/about"    style="color:var(--text-muted);text-decoration:none;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">About</a>
        </div>

        <!-- Theme toggle -->
        <button id="theme-toggle" aria-label="Toggle theme" style="display:flex;align-items:center;gap:8px;background:none;border:none;cursor:pointer;padding:4px;">
          <!-- Moon icon -->
          <svg id="icon-moon" width="14" height="14" fill="none" stroke="var(--text-muted)" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1111.21 3a7 7 0 009.79 9.79z"/>
          </svg>
          <div class="toggle-track">
            <div class="toggle-thumb"></div>
          </div>
          <!-- Sun icon -->
          <svg id="icon-sun" width="14" height="14" fill="none" stroke="var(--text-muted)" stroke-width="1.5" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="4"/><path stroke-linecap="round" d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32 1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41m11.32-11.32 1.41-1.41"/>
          </svg>
        </button>

        <a href="#newsletter" style="font-size:0.8rem;padding:6px 16px;border-radius:999px;border:1px solid color-mix(in srgb, var(--brand) 50%, transparent);color:var(--brand);text-decoration:none;">
          Subscribe
        </a>
      </div>
    </div>
  </nav>

  <main style="padding-top:56px;">
    <slot />
  </main>

  <!-- FOOTER -->
  <footer style="border-top:1px solid var(--border);margin-top:6rem;">
    <div style="max-width:72rem;margin:0 auto;padding:3rem 1.5rem;display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:2rem;">
      <div style="grid-column:span 2;">
        <div style="font-family:'Syne',sans-serif;font-size:1.1rem;font-weight:700;margin-bottom:0.75rem;">
          qubits<span style="color:var(--brand);">to</span>ai
        </div>
        <p style="font-size:0.875rem;color:var(--text-muted);line-height:1.6;max-width:20rem;">
          Computer science from the ground up. No shortcuts — deep understanding built layer by layer.
        </p>
      </div>
      <div>
        <div style="font-size:0.7rem;font-family:'JetBrains Mono',monospace;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:1rem;">Learn</div>
        <div style="display:flex;flex-direction:column;gap:0.5rem;font-size:0.875rem;">
          {['hardware','systems','compilers','web','ml','agents'].map(t => (
            <a href={`/learn/${t}`} style="color:var(--text-muted);text-decoration:none;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'">{t.charAt(0).toUpperCase()+t.slice(1)}</a>
          ))}
        </div>
      </div>
      <div>
        <div style="font-size:0.7rem;font-family:'JetBrains Mono',monospace;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:1rem;">Connect</div>
        <div style="display:flex;flex-direction:column;gap:0.5rem;font-size:0.875rem;">
          <a href="https://github.com/qubitstoai" style="color:var(--text-muted);text-decoration:none;">GitHub</a>
          <a href="https://youtube.com/@qubitstoai" style="color:var(--text-muted);text-decoration:none;">YouTube</a>
          <a href="https://x.com/qubitstoai" style="color:var(--text-muted);text-decoration:none;">X / Twitter</a>
        </div>
      </div>
    </div>
    <div style="border-top:1px solid var(--border);">
      <div style="max-width:72rem;margin:0 auto;padding:1rem 1.5rem;display:flex;justify-content:space-between;font-size:0.75rem;color:var(--text-faint);">
        <span>© 2025 qubitstoai.com</span>
        <span>From NAND gates to AI agents</span>
      </div>
    </div>
  </footer>

  <script>
    // Theme toggle
    const btn = document.getElementById('theme-toggle');
    btn?.addEventListener('click', () => {
      const html = document.documentElement;
      const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
      html.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
    });
  </script>
</body>
</html>
