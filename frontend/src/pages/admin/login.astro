---
export const prerender = false;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>Login — qubitstoai admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet"/>
  <script>
    (function(){var t=localStorage.getItem('theme')||'dark';document.documentElement.setAttribute('data-theme',t);})();
  </script>
  <style>
    :root,[data-theme="dark"]{--bg:#09090b;--bg-card:#18181b;--bg-hover:#27272a;--bg-active:#3f3f46;--border:#27272a;--border-s:#3f3f46;--fg:#fafafa;--fg-2:#e4e4e7;--fg-3:#a1a1aa;--fg-4:#71717a;--primary:#fafafa;--primary-fg:#09090b;--primary-hover:#e4e4e7;--success:#4ade80;--warning:#fbbf24;--danger:#f87171;--shadow-sm:0 1px 3px rgba(0,0,0,0.4);--shadow:0 4px 12px rgba(0,0,0,0.5);--nav-bg:rgba(9,9,11,0.90)}
    [data-theme="light"]{--bg:#fafafa;--bg-card:#ffffff;--bg-hover:#f4f4f5;--bg-active:#e4e4e7;--border:#e4e4e7;--border-s:#d4d4d8;--fg:#09090b;--fg-2:#3f3f46;--fg-3:#71717a;--fg-4:#a1a1aa;--primary:#18181b;--primary-fg:#fafafa;--primary-hover:#3f3f46;--success:#16a34a;--warning:#ca8a04;--danger:#dc2626;--shadow-sm:0 1px 3px rgba(0,0,0,0.06);--shadow:0 4px 12px rgba(0,0,0,0.08);--nav-bg:rgba(250,250,250,0.90)}
    :root{--font:'JetBrains Mono',monospace;--r:0.5rem;--r-sm:0.375rem}
  </style>
  <style>
    :root {
      --bg:#0a0a0a; --bg-card:#141414; --bg-hover:#1f1f1f;
      --border:#262626; --border-input:#3a3a3a;
      --fg:#fafafa; --fg-2:#a3a3a3; --fg-3:#737373; --fg-4:#525252;
      --primary:#fafafa; --primary-fg:#0a0a0a;
      --danger:#dc2626; --font:'JetBrains Mono',monospace; --r:0px;
    }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{font-family:var(--font);font-size:0.8125rem;background:var(--bg);color:var(--fg);min-height:100vh;display:flex;align-items:center;justify-content:center;-webkit-font-smoothing:antialiased}
    .card{width:100%;max-width:360px;padding:2rem;background:var(--bg-card);border:1px solid var(--border)}
    .logo{font-size:0.875rem;font-weight:700;margin-bottom:2rem;color:var(--fg)}
    .logo span{color:var(--fg-3)}
    h1{font-size:1rem;font-weight:700;margin-bottom:0.25rem;color:var(--fg)}
    .sub{font-size:0.72rem;color:var(--fg-3);margin-bottom:1.75rem}
    .field{margin-bottom:1rem}
    label{display:block;font-size:0.65rem;text-transform:uppercase;letter-spacing:0.08em;color:var(--fg-3);margin-bottom:0.375rem}
    input{width:100%;padding:8px 11px;background:var(--bg-card);border:1px solid var(--border-input);border-radius:var(--r);font-family:var(--font);font-size:0.8125rem;color:var(--fg);outline:none;transition:border-color 0.1s}
    input:focus{border-color:var(--fg-3)}
    input::placeholder{color:var(--fg-4)}
    .btn{width:100%;padding:9px;background:var(--primary);color:var(--primary-fg);border:1px solid var(--primary);border-radius:var(--r);font-family:var(--font);font-size:0.8125rem;font-weight:600;cursor:pointer;transition:background 0.1s;margin-top:0.5rem}
    .btn:hover{background:#e4e4e4}
    .err{color:var(--danger);font-size:0.72rem;margin-top:0.75rem;display:none}
  </style>
</head>
<body>
  <div class="card">
    <div class="logo">qubits<span>to</span>ai</div>
    <h1>Admin login</h1>
    <p class="sub">Sign in to manage posts and content.</p>
    <form id="form">
      <div class="field"><label>Email</label><input type="email" id="email" placeholder="you@email.com" required/></div>
      <div class="field"><label>Password</label><input type="password" id="password" placeholder="your password" required/></div>
      <button type="submit" class="btn">sign in →</button>
      <div class="err" id="err"></div>
    </form>
  </div>
  <script is:inline>
    if (localStorage.getItem('admin_token')) window.location.href = '/admin/dashboard';
    document.getElementById('form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const err = document.getElementById('err');
      err.style.display = 'none';
      const res = await fetch('/api/v1/admin/login', {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ email: document.getElementById('email').value, password: document.getElementById('password').value })
      });
      const data = await res.json();
      if (!res.ok) { err.textContent = data.error || 'login failed'; err.style.display = 'block'; return; }
      localStorage.setItem('admin_token', data.token);
      localStorage.setItem('admin_user', JSON.stringify(data.user));
      window.location.href = '/admin/dashboard';
    });
  </script>
</body>
</html>
