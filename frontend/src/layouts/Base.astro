---
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'qubitstoai — From NAND gates to AI agents',
  description = 'Deep, structured computer science from logic gates and circuits all the way to autonomous AI agents.',
} = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <!-- Inter — the shadcn standard font, free via Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    /* ─── shadcn/ui design tokens ─────────────────────────────────────── */
    :root {
      /* Background scale — slightly warm zinc */
      --background:       #09090b;   /* zinc-950 */
      --background-1:     #18181b;   /* zinc-900 — card bg */
      --background-2:     #27272a;   /* zinc-800 — hover, input bg */
      --background-3:     #3f3f46;   /* zinc-700 — active */

      /* Border */
      --border:           #27272a;   /* zinc-800 */
      --border-subtle:    #18181b;   /* zinc-900 — very faint */

      /* Text */
      --foreground:       #fafafa;   /* zinc-50 — primary text */
      --foreground-2:     #a1a1aa;   /* zinc-400 — secondary */
      --foreground-3:     #71717a;   /* zinc-500 — muted */
      --foreground-4:     #52525b;   /* zinc-600 — very muted */

      /* Accent — white/zinc approach like shadcn default */
      --primary:          #ffffff;
      --primary-fg:       #09090b;
      --primary-hover:    #e4e4e7;   /* zinc-200 */

      /* Accent color — a crisp indigo that pops on dark */
      --accent:           #6366f1;   /* indigo-500 */
      --accent-hover:     #818cf8;   /* indigo-400 */
      --accent-subtle:    #1e1b4b;   /* indigo-950 — bg tint */
      --accent-border:    #3730a3;   /* indigo-700 */

      /* Semantic */
      --success:  #22c55e;
      --warning:  #f59e0b;
      --danger:   #ef4444;
      --info:     #3b82f6;

      /* Track colors — muted to work on dark */
      --c-hardware:  #a78bfa;  /* violet-400 */
      --c-systems:   #34d399;  /* emerald-400 */
      --c-compilers: #fbbf24;  /* amber-400 */
      --c-web:       #60a5fa;  /* blue-400 */
      --c-ml:        #f87171;  /* red-400 */
      --c-agents:    #4ade80;  /* green-400 */

      /* Typography */
      --font-sans: 'Inter', system-ui, -apple-system, sans-serif;
      --font-mono: 'JetBrains Mono', 'Fira Code', monospace;

      /* Sizing */
      --radius:   0.5rem;   /* 8px — shadcn default */
      --radius-lg: 0.75rem;
      --radius-sm: 0.375rem;
    }

    /* ─── Reset ──────────────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }

    /* ─── Base ───────────────────────────────────────────────────────── */
    body {
      font-family: var(--font-sans);
      font-size: 0.9375rem;
      line-height: 1.6;
      background: var(--background);
      color: var(--foreground);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    a { color: inherit; text-decoration: none; }
    code, pre { font-family: var(--font-mono); }

    /* ─── shadcn-style component primitives ─────────────────────────── */

    /* Card */
    .card {
      background: var(--background-1);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      transition: border-color 0.15s;
    }
    .card:hover { border-color: var(--background-3); }

    /* Badge */
    .badge {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 0.72rem; font-weight: 500; font-family: var(--font-mono);
      padding: 2px 9px; border-radius: 999px;
      border: 1px solid var(--border);
      color: var(--foreground-2);
      background: var(--background-1);
    }
    .badge-accent {
      background: var(--accent-subtle);
      border-color: var(--accent-border);
      color: var(--accent-hover);
    }

    /* Button — primary (white) */
    .btn {
      display: inline-flex; align-items: center; gap: 7px;
      padding: 9px 18px; border-radius: var(--radius);
      font-family: var(--font-sans); font-size: 0.875rem; font-weight: 500;
      cursor: pointer; border: 1px solid transparent;
      transition: background 0.15s, color 0.15s, border-color 0.15s;
      white-space: nowrap;
    }
    .btn-primary {
      background: var(--primary); color: var(--primary-fg);
      border-color: var(--primary);
    }
    .btn-primary:hover { background: var(--primary-hover); border-color: var(--primary-hover); color: var(--primary-fg); }

    /* Button — outline */
    .btn-outline {
      background: transparent; color: var(--foreground);
      border-color: var(--border);
    }
    .btn-outline:hover { background: var(--background-2); }

    /* Button — ghost */
    .btn-ghost {
      background: transparent; color: var(--foreground-2);
      border-color: transparent;
    }
    .btn-ghost:hover { background: var(--background-2); color: var(--foreground); }

    /* Input */
    .input {
      width: 100%; padding: 9px 13px;
      background: var(--background-2); border: 1px solid var(--border);
      border-radius: var(--radius); color: var(--foreground);
      font-family: var(--font-sans); font-size: 0.9rem;
      outline: none; transition: border-color 0.15s, box-shadow 0.15s;
    }
    .input:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(99,102,241,0.15);
    }
    .input::placeholder { color: var(--foreground-4); }

    /* Separator */
    .separator { height: 1px; background: var(--border); }

    /* ─── Nav ────────────────────────────────────────────────────────── */
    #nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 50;
      height: 56px;
      background: rgba(9,9,11,0.92);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border-subtle);
    }
    .nav-inner {
      max-width: 72rem; margin: 0 auto; padding: 0 1.5rem;
      height: 100%; display: flex; align-items: center; justify-content: space-between;
    }
    .nav-logo {
      font-size: 0.9375rem; font-weight: 600; letter-spacing: -0.01em;
      color: var(--foreground);
    }
    .nav-logo span { color: var(--accent); }

    .nav-links { display: flex; align-items: center; gap: 0.25rem; }
    .nav-link {
      padding: 6px 12px; border-radius: var(--radius-sm);
      font-size: 0.875rem; font-weight: 400; color: var(--foreground-2);
      transition: background 0.1s, color 0.1s;
    }
    .nav-link:hover { background: var(--background-2); color: var(--foreground); }

    .nav-right { display: flex; align-items: center; gap: 0.5rem; }

    /* ─── Mobile menu ────────────────────────────────────────────────── */
    #mobile-menu {
      display: none; border-top: 1px solid var(--border);
      background: var(--background);
    }
    #mobile-menu.open { display: block; }
    #mobile-menu-inner {
      max-width: 72rem; margin: 0 auto;
      padding: 1rem 1.5rem; display: flex; flex-direction: column; gap: 0.25rem;
    }
    #mobile-menu a {
      padding: 8px 12px; border-radius: var(--radius-sm);
      font-size: 0.9rem; color: var(--foreground-2);
      transition: background 0.1s, color 0.1s;
    }
    #mobile-menu a:hover { background: var(--background-2); color: var(--foreground); }

    /* ─── Footer ─────────────────────────────────────────────────────── */
    footer {
      border-top: 1px solid var(--border);
      background: var(--background-1);
      margin-top: 6rem;
    }
    .footer-inner {
      max-width: 72rem; margin: 0 auto; padding: 3rem 1.5rem;
      display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 2.5rem;
    }
    .footer-logo { font-size: 0.9rem; font-weight: 600; color: var(--foreground); margin-bottom: 0.6rem; }
    .footer-logo span { color: var(--accent); }
    .footer-desc { font-size: 0.8125rem; color: var(--foreground-3); line-height: 1.7; max-width: 22rem; }
    .footer-col-title {
      font-family: var(--font-mono); font-size: 0.65rem;
      text-transform: uppercase; letter-spacing: 0.12em;
      color: var(--foreground-4); margin-bottom: 0.85rem;
    }
    .footer-links { display: flex; flex-direction: column; gap: 0.45rem; }
    .footer-links a { font-size: 0.8125rem; color: var(--foreground-3); transition: color 0.1s; }
    .footer-links a:hover { color: var(--foreground); }
    .footer-bottom {
      border-top: 1px solid var(--border);
      max-width: 72rem; margin: 0 auto;
      padding: 1rem 1.5rem;
      display: flex; justify-content: space-between; align-items: center;
      font-family: var(--font-mono); font-size: 0.72rem; color: var(--foreground-4);
    }

    /* ─── Prose ──────────────────────────────────────────────────────── */
    .prose {
      font-size: 0.9375rem; line-height: 1.8; color: var(--foreground-2);
    }
    .prose h1,.prose h2,.prose h3,.prose h4 { color: var(--foreground); font-weight: 600; margin-top: 2em; margin-bottom: 0.6em; }
    .prose h1 { font-size: 1.75rem; letter-spacing: -0.02em; }
    .prose h2 { font-size: 1.25rem; padding-bottom: 0.4em; border-bottom: 1px solid var(--border); }
    .prose h3 { font-size: 1.1rem; }
    .prose p { margin-bottom: 1.25em; }
    .prose a { color: var(--accent-hover); text-decoration: underline; text-underline-offset: 3px; }
    .prose strong { color: var(--foreground); font-weight: 600; }
    .prose code {
      font-family: var(--font-mono); font-size: 0.84em;
      background: var(--background-2); color: var(--accent-hover);
      padding: 2px 6px; border-radius: var(--radius-sm);
      border: 1px solid var(--border);
    }
    .prose pre {
      background: var(--background-1); border: 1px solid var(--border);
      border-radius: var(--radius-lg); padding: 1.25rem 1.5rem;
      overflow-x: auto; margin: 1.5em 0;
    }
    .prose pre code { background: none; border: none; padding: 0; color: var(--foreground-2); font-size: 0.875rem; }
    .prose blockquote {
      border-left: 2px solid var(--accent); padding: 0.5em 1.25em;
      margin: 1.5em 0; color: var(--foreground-3); font-style: italic;
    }
    .prose ul,.prose ol { margin: 1em 0 1em 1.5em; }
    .prose li { margin-bottom: 0.4em; }
    .prose hr { border: none; border-top: 1px solid var(--border); margin: 2em 0; }
    .prose table { width: 100%; border-collapse: collapse; margin: 1.5em 0; font-size: 0.875rem; }
    .prose th { background: var(--background-2); color: var(--foreground); padding: 0.6em 1em; border: 1px solid var(--border); text-align: left; font-weight: 500; }
    .prose td { padding: 0.55em 1em; border: 1px solid var(--border); }

    /* ─── Responsive ─────────────────────────────────────────────────── */
    @media (max-width: 768px) {
      .nav-links { display: none; }
      .nav-subscribe { display: none; }
      .footer-inner { grid-template-columns: 1fr; }
    }
    @media (min-width: 769px) { #menu-btn { display: none !important; } }
  </style>
</head>
<body>
  <!-- NAV -->
  <nav id="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">qubits<span>to</span>ai</a>

      <div class="nav-links">
        <a href="/learn"    class="nav-link">Learn</a>
        <a href="/blog"     class="nav-link">Blog</a>
        <a href="/projects" class="nav-link">Projects</a>
        <a href="/about"    class="nav-link">About</a>
      </div>

      <div class="nav-right">
        <a href="#newsletter" class="btn btn-outline" style="font-size:0.8rem;padding:6px 14px;">Subscribe</a>
        <button id="menu-btn" style="background:none;border:none;cursor:pointer;padding:6px;color:var(--foreground-3);display:none;" aria-label="menu">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <div id="mobile-menu">
    <div id="mobile-menu-inner">
      <a href="/learn">Learn</a>
      <a href="/blog">Blog</a>
      <a href="/projects">Projects</a>
      <a href="/about">About</a>
    </div>
  </div>

  <main style="padding-top:56px;">
    <slot />
  </main>

  <!-- FOOTER -->
  <footer>
    <div class="footer-inner">
      <div>
        <div class="footer-logo">qubits<span>to</span>ai</div>
        <p class="footer-desc">Computer science from the ground up. No shortcuts — deep understanding built layer by layer.</p>
      </div>
      <div>
        <div class="footer-col-title">Explore</div>
        <div class="footer-links">
          <a href="/learn/hardware">Hardware</a>
          <a href="/learn/systems">Systems</a>
          <a href="/learn/compilers">Compilers</a>
          <a href="/learn/web">Web</a>
          <a href="/learn/ml">ML</a>
          <a href="/learn/agents">AI Agents</a>
        </div>
      </div>
      <div>
        <div class="footer-col-title">Connect</div>
        <div class="footer-links">
          <a href="https://github.com/qubitstoai">GitHub</a>
          <a href="https://youtube.com/@qubitstoai">YouTube</a>
          <a href="https://x.com/qubitstoai">X / Twitter</a>
          <a href="/rss.xml">RSS</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© 2025 qubitstoai.com</span>
      <span>From NAND gates to AI agents</span>
    </div>
  </footer>

  <script>
    document.getElementById('menu-btn')?.addEventListener('click', () => {
      document.getElementById('mobile-menu')?.classList.toggle('open');
    });
  </script>
</body>
</html>
