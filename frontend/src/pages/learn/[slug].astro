---
export const prerender = false;
import Base from '../../layouts/Base.astro';
const slug = Astro.params.slug;
const API = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
let track: any = null;
let sections: any[] = [];
let lessons: any[] = [];
try {
  const [tr, sc, ls] = await Promise.all([
    fetch(`${API}/api/v1/tracks/${slug}`).then(r => r.ok ? r.json() : null),
    fetch(`${API}/api/v1/tracks/${slug}/sections`).then(r => r.ok ? r.json() : []),
    fetch(`${API}/api/v1/tracks/${slug}/lessons`).then(r => r.ok ? r.json() : []),
  ]);
  track = tr; sections = sc; lessons = ls;
} catch {}
const colors: Record<string,string> = { hardware:'#7C3AED',systems:'#059669',compilers:'#D97706',web:'#2563EB',ml:'#DC2626',agents:'#16A34A' };
const color = colors[slug as string] ?? '#2563EB';
---
<Base title={track ? `${track.title} — qubitstoai` : 'Not found'}>
  <div style="max-width:52rem;margin:0 auto;padding:4rem 1.75rem 6rem;">
    {!track ? (
      <div style="text-align:center;padding:4rem 0;">
        <p style="color:var(--ink-3);">Track not found. <a href="/learn">Back to topics →</a></p>
      </div>
    ) : (
      <>
        <a href="/learn" style="display:inline-flex;align-items:center;gap:6px;font-size:var(--text-sm);color:var(--ink-3);margin-bottom:2rem;font-weight:500;text-decoration:none;" onmouseover="this.style.color='var(--blue)'" onmouseout="this.style.color='var(--ink-3)'">
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 17l-5-5m0 0l5-5m-5 5h12"/></svg>
          All topics
        </a>
        <div style="display:flex;align-items:flex-start;gap:1rem;margin-bottom:3rem;">
          <div style={`width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-weight:700;font-size:1.2rem;flex-shrink:0;background:${color}12;color:${color};border:1px solid ${color}22`}>{(slug as string).charAt(0).toUpperCase()}</div>
          <div>
            <h1 style="font-family:var(--font-display);font-size:var(--text-3xl);font-weight:700;color:var(--ink);letter-spacing:-0.02em;margin-bottom:0.4rem;">{track.title}</h1>
            <p style="color:var(--ink-3);font-size:var(--text-base);">{track.description}</p>
          </div>
        </div>
        {sections.length > 0 ? (
          <div style="display:flex;flex-direction:column;gap:0.85rem;">
            {sections.map((section: any) => (
              <a href={`/learn/${slug}/${section.slug}`} style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;padding:1.5rem;background:var(--bg-card);border:1px solid var(--border);border-radius:12px;text-decoration:none;transition:border-color 0.15s,box-shadow 0.15s;" onmouseover="this.style.borderColor='#C2C0BA';this.style.boxShadow='0 2px 12px rgba(0,0,0,0.07)'" onmouseout="this.style.borderColor='var(--border)';this.style.boxShadow='none'">
                <div>
                  <h2 style="font-family:var(--font-display);font-size:var(--text-xl);font-weight:600;color:var(--ink);margin-bottom:0.35rem;">{section.title}</h2>
                  <p style="font-size:var(--text-sm);color:var(--ink-3);line-height:1.6;">{section.description}</p>
                </div>
                <div style="display:flex;align-items:center;gap:0.75rem;flex-shrink:0;margin-top:4px;">
                  {section.post_count > 0 && <span style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--ink-4);">{section.post_count} article{section.post_count !== 1 ? 's' : ''}</span>}
                  <svg width="15" height="15" fill="none" stroke="var(--ink-4)" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                </div>
              </a>
            ))}
          </div>
        ) : lessons.length > 0 ? (
          <div>
            {lessons.map((lesson: any) => (
              <a href={`/learn/${slug}/${lesson.slug}`} style="display:flex;align-items:center;gap:1rem;padding:1.1rem 1rem;border-bottom:1px solid var(--border-light);border-radius:8px;text-decoration:none;transition:background 0.15s;" onmouseover="this.style.background='var(--bg-raised)'" onmouseout="this.style.background='transparent'">
                <span style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--ink-4);width:28px;flex-shrink:0;">{String(lesson.sort_order).padStart(2,'0')}</span>
                <div style="flex:1;">
                  <div style="font-family:var(--font-display);font-weight:600;color:var(--ink);font-size:1rem;">{lesson.title}</div>
                  <div style="font-size:var(--text-sm);color:var(--ink-4);margin-top:0.2rem;">{lesson.description}</div>
                </div>
                <span style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--ink-4);">{lesson.read_mins} min</span>
              </a>
            ))}
          </div>
        ) : (
          <div style="border:1.5px dashed var(--border);border-radius:12px;padding:3.5rem;text-align:center;">
            <div style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--ink-4);margin-bottom:0.5rem;">// coming soon</div>
            <p style="color:var(--ink-3);font-size:var(--text-sm);">Content is being written. <a href="/#newsletter">Subscribe to get notified →</a></p>
          </div>
        )}
      </>
    )}
  </div>
</Base>
