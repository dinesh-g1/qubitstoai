---
import Base from '../../layouts/Base.astro';
const projects = [
  { title:'NAND simulator',   desc:'Boolean logic gate simulator in Go. Simulate any circuit from NAND primitives.',      tag:'Hardware', dot:'var(--c-hw)', status:'In progress', github:'https://github.com/qubitstoai/nand-simulator' },
  { title:'Mini CPU',         desc:'A 16-bit CPU built on breadboard. Custom instruction set.',                            tag:'Hardware', dot:'var(--c-hw)', status:'Planned',     github:'#' },
  { title:'qsh — tiny shell', desc:'POSIX-compatible shell in C. Pipes, redirects, job control, builtins.',               tag:'Systems',  dot:'var(--c-sy)', status:'Planned',     github:'#' },
  { title:'tinycompiler',     desc:'Compiler from a simple language to x86 assembly. Lexer → parser → AST → codegen.',   tag:'Compilers',dot:'var(--c-co)', status:'Planned',     github:'#' },
  { title:'qubitstoai.com',   desc:'This website. Go + Astro + PostgreSQL, self-hosted. All open source.',                tag:'Web',      dot:'var(--c-wb)', status:'Live',        github:'https://github.com/qubitstoai/site' },
];
---
<Base title="Projects — qubitstoai">
<div style="max-width:56rem;margin:0 auto;padding:3rem 1.5rem 6rem;">
  <div style="padding-bottom:1.5rem;border-bottom:1px solid var(--border);margin-bottom:1.5rem;">
    <div style="font-size:0.6rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--fg-4);margin-bottom:0.3rem;">open source</div>
    <h1 style="font-size:1.5rem;font-weight:700;letter-spacing:-0.02em;color:var(--fg);">Projects</h1>
    <p style="font-size:0.75rem;color:var(--fg-3);margin-top:0.35rem;">Every concept gets built. All repos are public on GitHub.</p>
  </div>
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:1px;background:var(--border);border:1px solid var(--border);">
    {projects.map(p => (
      <a href={p.github} target="_blank" rel="noopener noreferrer" style="display:block;padding:1.125rem;background:var(--background);transition:background 0.1s;text-decoration:none;" onmouseover="this.style.background='var(--bg-hover)'" onmouseout="this.style.background='var(--background)'">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem;">
          <div style="display:flex;align-items:center;gap:0.5rem;">
            <span style={`width:5px;height:5px;border-radius:50%;background:${p.dot}`}></span>
            <span style="font-size:0.6rem;text-transform:uppercase;letter-spacing:0.06em;color:var(--fg-4);">{p.tag}</span>
          </div>
          <span style={`font-size:0.6rem;color:${p.status==='Live'?'var(--success)':p.status==='In progress'?'var(--warning)':'var(--fg-4)'}`}>{p.status==='Live'?'●':p.status==='In progress'?'◐':'○'} {p.status}</span>
        </div>
        <div style="font-size:0.8125rem;font-weight:600;color:var(--fg);margin-bottom:0.35rem;">{p.title}</div>
        <div style="font-size:0.7rem;color:var(--fg-3);line-height:1.5;margin-bottom:0.875rem;">{p.desc}</div>
        <div style="display:flex;align-items:center;gap:4px;font-size:0.6rem;color:var(--fg-4);">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          GitHub
        </div>
      </a>
    ))}
  </div>
</div>
</Base>
