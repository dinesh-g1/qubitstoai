---
import Base from '../layouts/Base.astro';
const API = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
const tracks = [
  { slug:'hardware',  title:'Hardware',          sub:'NAND gates → CPU architecture',    color:'var(--c-hardware)' },
  { slug:'systems',   title:'Systems',            sub:'Assembly → OS internals',          color:'var(--c-systems)'  },
  { slug:'compilers', title:'Compilers & VMs',    sub:'Lexers → bytecode → runtimes',    color:'var(--c-compilers)'},
  { slug:'web',       title:'Web & Backend',      sub:'HTTP → full-stack & architecture', color:'var(--c-web)'      },
  { slug:'ml',        title:'ML & Deep Learning', sub:'Math foundations → transformers',  color:'var(--c-ml)'       },
  { slug:'agents',    title:'AI Agents',          sub:'Planning → autonomous systems',    color:'var(--c-agents)'   },
];
let posts: any[] = [];
try {
  const res = await fetch(`${API}/api/v1/posts`);
  if (res.ok) posts = await res.json();
} catch {}
---
<Base>
<style>
  .wrap { max-width: 72rem; margin: 0 auto; padding: 0 1.5rem; }

  /* ── Hero ── */
  .hero { padding: 6rem 0 4.5rem; }
  .hero-eyebrow {
    display: inline-flex; align-items: center; gap: 6px;
    margin-bottom: 1.75rem;
  }
  .hero h1 {
    font-size: clamp(2.25rem, 5.5vw, 3.75rem);
    font-weight: 700; line-height: 1.1;
    letter-spacing: -0.03em; color: var(--foreground);
    margin-bottom: 1.25rem; max-width: 640px;
  }
  .hero-sub {
    font-size: 1rem; color: var(--foreground-3);
    line-height: 1.7; max-width: 460px; margin-bottom: 2.25rem;
  }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-bottom: 3.5rem; }
  .hero-stats {
    display: flex; flex-wrap: wrap; gap: 2rem;
    padding-top: 2rem; border-top: 1px solid var(--border);
  }
  .stat-val { font-size: 1.375rem; font-weight: 700; color: var(--foreground); }
  .stat-val.accent { color: var(--accent); }
  .stat-lbl { font-size: 0.8rem; color: var(--foreground-4); margin-left: 5px; }

  /* ── Section ── */
  .section { padding: 4rem 0; border-top: 1px solid var(--border); }
  .section-eyebrow {
    font-family: var(--font-mono); font-size: 0.7rem;
    text-transform: uppercase; letter-spacing: 0.1em;
    color: var(--foreground-4); margin-bottom: 0.5rem;
  }
  .section-title {
    font-size: 1.375rem; font-weight: 600;
    color: var(--foreground); letter-spacing: -0.01em; margin-bottom: 0.4rem;
  }
  .section-sub { font-size: 0.875rem; color: var(--foreground-3); max-width: 400px; }

  /* ── Track cards ── */
  .tracks-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem; margin-top: 2rem;
  }
  .track-card {
    display: block; padding: 1.25rem;
    background: var(--background-1); border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    transition: background 0.15s, border-color 0.15s;
  }
  .track-card:hover { background: var(--background-2); border-color: var(--background-3); }
  .track-icon {
    width: 32px; height: 32px; border-radius: var(--radius-sm);
    display: flex; align-items: center; justify-content: center;
    font-size: 0.8rem; font-weight: 600; margin-bottom: 0.85rem;
    font-family: var(--font-mono);
  }
  .track-name { font-size: 0.9375rem; font-weight: 500; color: var(--foreground); margin-bottom: 0.3rem; }
  .track-sub  { font-size: 0.8rem; color: var(--foreground-4); line-height: 1.5; }

  /* ── Posts ── */
  .posts-list { margin-top: 1.5rem; }
  .post-item {
    display: flex; align-items: flex-start; gap: 1rem;
    padding: 1rem 0.75rem; border-radius: var(--radius);
    transition: background 0.1s;
  }
  .post-item:hover { background: var(--background-2); }
  .post-num { font-family: var(--font-mono); font-size: 0.7rem; color: var(--foreground-4); width: 20px; flex-shrink: 0; padding-top: 3px; }
  .post-tag { font-family: var(--font-mono); font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--accent); margin-bottom: 0.25rem; }
  .post-title { font-size: 0.9375rem; font-weight: 500; color: var(--foreground); line-height: 1.4; }
  .post-meta { font-family: var(--font-mono); font-size: 0.7rem; color: var(--foreground-4); margin-top: 0.25rem; }

  /* ── Newsletter ── */
  .nl-section {
    border-top: 1px solid var(--border);
    padding: 4.5rem 0;
  }
  .nl-box {
    max-width: 440px; margin: 0 auto; text-align: center;
  }
  .nl-form { display: flex; gap: 0.5rem; margin-top: 1.5rem; }
  .nl-form .input { background: var(--background-2); }

  /* ── Empty state ── */
  .empty {
    border: 1px dashed var(--border); border-radius: var(--radius-lg);
    padding: 3rem; text-align: center; margin-top: 1.5rem;
  }
  .empty-label { font-family: var(--font-mono); font-size: 0.7rem; color: var(--foreground-4); margin-bottom: 0.5rem; }
  .empty p { font-size: 0.875rem; color: var(--foreground-3); }

  @media (max-width: 768px) {
    .tracks-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .tracks-grid { grid-template-columns: 1fr; }
    .nl-form { flex-direction: column; }
  }
</style>

<!-- HERO -->
<section>
  <div class="wrap">
    <div class="hero">
      <div class="hero-eyebrow">
        <span class="badge badge-accent">
          <span style="width:5px;height:5px;border-radius:50%;background:var(--accent);animation:pulse 2s infinite;flex-shrink:0;"></span>
          Building in public
        </span>
      </div>
      <h1>Computer science,<br/>from the ground up.</h1>
      <p class="hero-sub">From a single NAND gate to autonomous AI agents. Every layer explained, every concept built from scratch.</p>
      <div class="hero-actions">
        <a href="/learn" class="btn btn-primary">
          Start exploring
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
        <a href="/blog" class="btn btn-outline">Read the blog</a>
      </div>
      <div class="hero-stats">
        <div><span class="stat-val">6</span><span class="stat-lbl">topics</span></div>
        <div><span class="stat-val">120+</span><span class="stat-lbl">planned articles</span></div>
        <div><span class="stat-val accent">Free</span><span class="stat-lbl">forever</span></div>
      </div>
    </div>
  </div>
</section>

<!-- TOPICS -->
<section class="section">
  <div class="wrap">
    <div class="section-eyebrow">Exploring</div>
    <div style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
      <div>
        <div class="section-title">Topics I'm diving into</div>
        <div class="section-sub">From hardware to AI — in whatever order curiosity takes me.</div>
      </div>
      <a href="/learn" class="btn btn-ghost" style="font-size:0.8rem;padding:6px 12px;">
        View all
        <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </a>
    </div>
    <div class="tracks-grid">
      {tracks.map((track, i) => (
        <a href={`/learn/${track.slug}`} class="track-card">
          <div class="track-icon" style={`background:color-mix(in srgb,${track.color} 15%,var(--background-2));color:${track.color}`}>
            {String(i+1).padStart(2,'0')}
          </div>
          <div class="track-name">{track.title}</div>
          <div class="track-sub">{track.sub}</div>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- POSTS -->
<section class="section">
  <div class="wrap">
    <div style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:1rem;margin-bottom:0;">
      <div>
        <div class="section-eyebrow">Latest</div>
        <div class="section-title">Recent articles</div>
      </div>
      <a href="/blog" class="btn btn-ghost" style="font-size:0.8rem;padding:6px 12px;">
        All articles
        <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </a>
    </div>
    {posts.length > 0 ? (
      <div class="posts-list">
        {posts.slice(0,5).map((post: any, i: number) => (
          <a href={`/blog/${post.slug}`} class="post-item" style="display:flex;">
            <span class="post-num">{String(i+1).padStart(2,'0')}</span>
            <div style="flex:1;">
              <div class="post-tag">{post.tag}</div>
              <div class="post-title">{post.title}</div>
              <div class="post-meta">{post.read_mins} min read</div>
            </div>
            <svg width="14" height="14" fill="none" stroke="var(--foreground-4)" stroke-width="1.5" viewBox="0 0 24 24" style="flex-shrink:0;margin-top:4px;"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
        ))}
      </div>
    ) : (
      <div class="empty">
        <div class="empty-label">// coming soon</div>
        <p>First articles dropping soon.</p>
      </div>
    )}
  </div>
</section>

<!-- NEWSLETTER -->
<section class="nl-section" id="newsletter">
  <div class="wrap">
    <div class="nl-box">
      <div class="section-eyebrow" style="text-align:center;">Newsletter</div>
      <div style="font-size:1.25rem;font-weight:600;color:var(--foreground);margin:0.4rem 0;">Follow the build</div>
      <p style="font-size:0.875rem;color:var(--foreground-3);line-height:1.7;">What I learned, what I built, what broke. No spam.</p>
      <form id="nl-form" class="nl-form">
        <input type="email" id="nl-email" placeholder="you@email.com" required class="input"/>
        <button type="submit" class="btn btn-primary" style="flex-shrink:0;">Subscribe</button>
      </form>
      <p id="nl-msg" style="margin-top:0.6rem;font-size:0.8rem;color:var(--foreground-3);display:none;font-family:var(--font-mono);"></p>
    </div>
  </div>
</section>

<style>
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }
</style>

<script>
  const form = document.getElementById('nl-form') as HTMLFormElement;
  const msg = document.getElementById('nl-msg') as HTMLElement;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (document.getElementById('nl-email') as HTMLInputElement).value;
    try {
      const res = await fetch('/api/v1/newsletter/subscribe', {
        method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({email}),
      });
      msg.textContent = res.ok ? '✓ Subscribed!' : 'Something went wrong.';
      msg.style.color = res.ok ? 'var(--success)' : 'var(--danger)';
      msg.style.display = 'block';
      if (res.ok) form.reset();
    } catch { msg.textContent = 'Network error.'; msg.style.display = 'block'; }
  });
</script>
</Base>
