---
export const prerender = false;
import Base from '../../layouts/Base.astro';
const { slug } = Astro.params;
const API = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
let post: any = null;
try { const r = await fetch(`${API}/api/v1/posts/${slug}`); if (r.ok) post = await r.json(); } catch {}
---
<Base title={post ? `${post.title} — qubitstoai` : 'Not found'} description={post?.description}>
  {!post ? (
    <div style="max-width:48rem;margin:0 auto;padding:5rem 1.5rem;text-align:center;">
      <div style="font-size:0.65rem;color:var(--fg-4);margin-bottom:0.4rem;">404</div>
      <p style="font-size:0.8125rem;color:var(--fg-3);">not found. <a href="/blog" style="color:var(--fg);text-decoration:underline;">back →</a></p>
    </div>
  ) : (
    <div style="max-width:44rem;margin:0 auto;padding:2.5rem 1.5rem 6rem;">
      <a href="/blog" style="display:inline-flex;align-items:center;gap:5px;font-size:0.7rem;color:var(--fg-4);margin-bottom:2rem;transition:color 0.1s;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--fg-4)'">
        <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 17l-5-5m0 0l5-5m-5 5h12"/></svg>
        blog
      </a>
      <header style="padding-bottom:1.5rem;border-bottom:1px solid var(--border);margin-bottom:2rem;">
        <div style="margin-bottom:0.625rem;">
          <span style="font-size:0.6rem;text-transform:uppercase;letter-spacing:0.08em;background:var(--bg-hover);color:var(--fg-3);padding:2px 7px;border:1px solid var(--border);">{post.tag}</span>
        </div>
        <h1 style="font-size:clamp(1.25rem,3.5vw,1.875rem);font-weight:700;letter-spacing:-0.02em;color:var(--fg);line-height:1.2;margin-bottom:0.75rem;">{post.title}</h1>
        {post.description && <p style="font-size:0.8125rem;color:var(--fg-3);line-height:1.65;">{post.description}</p>}
        <div style="display:flex;align-items:center;gap:0.875rem;margin-top:0.75rem;font-size:0.65rem;color:var(--fg-4);">
          <span>{post.read_mins} min read</span>
          <span>·</span>
          <span>{new Date(post.created_at).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})}</span>
        </div>
      </header>
      {post.content
        ? <article class="prose" set:html={post.content} />
        : <div style="padding:3rem;border:1px dashed var(--border);text-align:center;"><div style="font-size:0.65rem;color:var(--fg-4);">// content coming soon</div></div>
      }
    </div>
  )}
</Base>
