---
import Base from '../layouts/Base.astro';
const API = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
const tracks = [
  { slug:'hardware',  title:'Hardware',          sub:'NAND gates → CPU architecture',   color:'#7C3AED' },
  { slug:'systems',   title:'Systems',            sub:'Assembly → OS internals',         color:'#059669' },
  { slug:'compilers', title:'Compilers & VMs',    sub:'Lexers → bytecode → runtimes',   color:'#D97706' },
  { slug:'web',       title:'Web & Backend',      sub:'HTTP → full-stack & architecture',color:'#2563EB' },
  { slug:'ml',        title:'ML & Deep Learning', sub:'Math foundations → transformers', color:'#DC2626' },
  { slug:'agents',    title:'AI Agents',          sub:'Planning → autonomous systems',   color:'#16A34A' },
];
let posts: any[] = [];
try {
  const res = await fetch(`${API}/api/v1/posts`);
  if (res.ok) posts = await res.json();
} catch {}
---
<Base>
  <style>
    /* Hero */
    .hero { max-width: 72rem; margin: 0 auto; padding: 6rem 1.75rem 5rem; }
    .hero-badge {
      display: inline-flex; align-items: center; gap: 8px;
      font-family: var(--font-mono); font-size: var(--text-xs);
      color: var(--blue); background: var(--blue-light);
      border: 1px solid var(--blue-border);
      border-radius: 999px; padding: 5px 14px; margin-bottom: 2rem;
    }
    .badge-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--blue); animation: pulse 2s infinite; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.35} }
    .hero h1 {
      font-family: var(--font-display);
      font-size: clamp(2.75rem, 6.5vw, 4.5rem);
      font-weight: 700; line-height: 1.05;
      letter-spacing: -0.025em; color: var(--ink);
      margin-bottom: 1.5rem; max-width: 700px;
    }
    .hero h1 em { font-style: italic; color: var(--blue); }
    .hero-sub {
      font-size: var(--text-lg); color: var(--ink-3);
      line-height: 1.7; max-width: 520px; margin-bottom: 2.5rem;
    }
    .hero-buttons { display: flex; flex-wrap: wrap; gap: 0.85rem; margin-bottom: 4rem; }
    .hero-divider {
      border-top: 1px solid var(--border);
      padding-top: 2rem;
      display: flex; flex-wrap: wrap; gap: 2.5rem;
    }
    .stat-num { font-family: var(--font-display); font-size: 1.6rem; font-weight: 700; color: var(--ink); }
    .stat-num.blue { color: var(--blue); }
    .stat-label { font-size: var(--text-sm); color: var(--ink-4); margin-left: 6px; }

    /* Tracks section */
    .section { max-width: 72rem; margin: 0 auto; padding: 4rem 1.75rem; }
    .section-header { margin-bottom: 2.5rem; }
    .tracks-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
      gap: 1rem;
    }
    .track-card {
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: 12px; padding: 1.5rem;
      transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
      text-decoration: none; display: block;
    }
    .track-card:hover {
      border-color: #C2C0BA;
      box-shadow: 0 4px 16px rgba(0,0,0,0.07);
      transform: translateY(-2px);
      color: inherit;
    }
    .track-num {
      width: 38px; height: 38px; border-radius: 9px;
      display: flex; align-items: center; justify-content: center;
      font-family: var(--font-display); font-weight: 700; font-size: 1rem;
      margin-bottom: 1rem;
    }
    .track-name {
      font-family: var(--font-display); font-size: 1.05rem;
      font-weight: 600; color: var(--ink); margin-bottom: 0.35rem;
    }
    .track-sub { font-size: var(--text-sm); color: var(--ink-4); }

    /* Posts section */
    .post-row {
      display: flex; align-items: flex-start; gap: 1.25rem;
      padding: 1.25rem 1rem; border-radius: 10px;
      border-bottom: 1px solid var(--border-light);
      transition: background 0.15s; text-decoration: none;
    }
    .post-row:hover { background: var(--bg-raised); color: inherit; }
    .post-num { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--ink-4); margin-top: 3px; width: 22px; flex-shrink: 0; }
    .post-tag { font-family: var(--font-mono); font-size: 0.7rem; color: var(--blue); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.3rem; }
    .post-title { font-family: var(--font-display); font-size: 1.05rem; font-weight: 600; color: var(--ink); line-height: 1.35; }
    .post-meta { font-size: var(--text-xs); color: var(--ink-4); margin-top: 0.3rem; font-family: var(--font-mono); }
    .empty-box {
      border: 1.5px dashed var(--border); border-radius: 12px;
      padding: 3.5rem; text-align: center; margin-top: 1.5rem;
    }

    /* Newsletter */
    .newsletter-section {
      border-top: 1px solid var(--border);
      background: var(--bg-card); padding: 5rem 1.75rem;
    }
    .newsletter-inner { max-width: 480px; margin: 0 auto; text-align: center; }
    .nl-form { display: flex; gap: 0.65rem; margin-top: 1.75rem; }
    .nl-input {
      flex: 1; padding: 11px 15px;
      border: 1.5px solid var(--border); border-radius: 9px;
      font-family: var(--font-body); font-size: var(--text-sm);
      color: var(--ink); background: var(--bg);
      outline: none; transition: border-color 0.15s;
    }
    .nl-input:focus { border-color: var(--blue); }
    .nl-input::placeholder { color: var(--ink-4); }

    @media (max-width: 640px) {
      .nl-form { flex-direction: column; }
      .tracks-grid { grid-template-columns: 1fr; }
    }
  </style>

  <!-- HERO -->
  <section>
    <div class="hero">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        Building in public · learning out of curiosity
      </div>
      <h1>Computer science,<br/><em>from the ground up.</em></h1>
      <p class="hero-sub">From a single NAND gate to autonomous AI agents. Every layer explained, every concept built from scratch.</p>
      <div class="hero-buttons">
        <a href="/learn" class="btn-primary">
          Start exploring
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
        <a href="/blog" class="btn-ghost">Read the blog</a>
      </div>
      <div class="hero-divider">
        <div><span class="stat-num">6</span><span class="stat-label">topics</span></div>
        <div><span class="stat-num">120+</span><span class="stat-label">planned articles</span></div>
        <div><span class="stat-num blue">Free</span><span class="stat-label">forever</span></div>
      </div>
    </div>
  </section>

  <!-- TOPICS -->
  <section class="section" style="border-top: 1px solid var(--border-light);">
    <div class="section-header">
      <div class="label" style="margin-bottom:0.6rem;">Exploring</div>
      <h2 class="section-title">Topics I'm diving into</h2>
      <p style="color:var(--ink-3);font-size:var(--text-base);margin-top:0.6rem;max-width:480px;">From hardware to AI — explored in whatever order curiosity takes me.</p>
    </div>
    <div class="tracks-grid">
      {tracks.map((track, i) => (
        <a href={`/learn/${track.slug}`} class="track-card">
          <div class="track-num" style={`background:${track.color}12;color:${track.color};border:1px solid ${track.color}25`}>{i+1}</div>
          <div class="track-name">{track.title}</div>
          <div class="track-sub">{track.sub}</div>
        </a>
      ))}
    </div>
  </section>

  <!-- RECENT POSTS -->
  <section class="section" style="padding-top:0;">
    <div class="section-header" style="display:flex;align-items:flex-end;justify-content:space-between;">
      <div>
        <div class="label" style="margin-bottom:0.6rem;">Latest</div>
        <h2 class="section-title">Recent articles</h2>
      </div>
      <a href="/blog" style="font-size:var(--text-sm);font-weight:500;color:var(--blue);">All articles →</a>
    </div>
    {posts.length > 0 ? (
      <div>
        {posts.slice(0,5).map((post: any, i: number) => (
          <a href={`/blog/${post.slug}`} class="post-row">
            <span class="post-num">{String(i+1).padStart(2,'0')}</span>
            <div style="flex:1;">
              <div class="post-tag">{post.tag}</div>
              <div class="post-title">{post.title}</div>
              <div class="post-meta">{post.read_mins} min read</div>
            </div>
            <svg width="15" height="15" fill="none" stroke="var(--ink-4)" stroke-width="1.5" viewBox="0 0 24 24" style="flex-shrink:0;margin-top:4px;"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
        ))}
      </div>
    ) : (
      <div class="empty-box">
        <div style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--ink-4);margin-bottom:0.5rem;">// coming soon</div>
        <p style="color:var(--ink-3);font-size:var(--text-sm);">First articles dropping soon. Subscribe to be notified.</p>
      </div>
    )}
  </section>

  <!-- NEWSLETTER -->
  <section class="newsletter-section" id="newsletter">
    <div class="newsletter-inner">
      <div class="label" style="margin-bottom:0.6rem;">Newsletter</div>
      <h2 style="font-family:var(--font-display);font-size:var(--text-2xl);font-weight:700;color:var(--ink);margin-bottom:0.6rem;">Follow the build</h2>
      <p style="color:var(--ink-3);font-size:var(--text-sm);line-height:1.7;">
        Weekly dispatch: what I learned, what I built, what broke. No spam. Unsubscribe anytime.
      </p>
      <form id="nl-form" class="nl-form">
        <input type="email" id="nl-email" placeholder="you@email.com" required class="nl-input"/>
        <button type="submit" class="btn-primary" style="white-space:nowrap;">Subscribe →</button>
      </form>
      <p id="nl-msg" style="margin-top:0.75rem;font-size:var(--text-sm);color:var(--ink-3);display:none;"></p>
    </div>
  </section>

  <script>
    const form = document.getElementById('nl-form') as HTMLFormElement;
    const msg = document.getElementById('nl-msg') as HTMLElement;
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = (document.getElementById('nl-email') as HTMLInputElement).value;
      try {
        const res = await fetch('/api/v1/newsletter/subscribe', {
          method: 'POST', headers: {'Content-Type':'application/json'},
          body: JSON.stringify({ email }),
        });
        msg.textContent = res.ok ? 'Subscribed! Talk soon.' : 'Something went wrong — try again.';
        msg.style.color = res.ok ? 'var(--blue)' : '#DC2626';
        msg.style.display = 'block';
        if (res.ok) form.reset();
      } catch {
        msg.textContent = 'Network error.';
        msg.style.display = 'block';
      }
    });
  </script>
</Base>
