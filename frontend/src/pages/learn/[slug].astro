export const prerender = false;
---
import Base from '../../layouts/Base.astro';
const slug = Astro.params.slug;
const API = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';

let track: any = null;
let sections: any[] = [];
let lessons: any[] = [];

try {
  const [tr, sc, ls] = await Promise.all([
    fetch(`${API}/api/v1/tracks/${slug}`).then(r => r.ok ? r.json() : null),
    fetch(`${API}/api/v1/tracks/${slug}/sections`).then(r => r.ok ? r.json() : []),
    fetch(`${API}/api/v1/tracks/${slug}/lessons`).then(r => r.ok ? r.json() : []),
  ]);
  track = tr;
  sections = sc;
  lessons = ls;
} catch {}

const trackColors: Record<string, string> = {
  hardware: '#7F77DD', systems: '#1D9E75', compilers: '#BA7517',
  web: '#185FA5', ml: '#993C1D', agents: '#3B6D11',
};
const color = trackColors[slug as string] ?? '#7F77DD';
---
<Base title={track ? `${track.title} — qubitstoai` : 'Track not found'}>
  <div class="max-w-4xl mx-auto px-6 py-16">

    {!track ? (
      <div class="text-center py-24">
        <div class="text-zinc-600 font-mono text-sm mb-2">// 404</div>
        <p class="text-zinc-400">Track not found. <a href="/learn" class="text-brand-400 underline">Back to all topics</a></p>
      </div>
    ) : (
      <>
        <div class="mb-3">
          <a href="/learn" class="text-xs font-mono text-zinc-500 hover:text-brand-400 transition-colors">← All topics</a>
        </div>

        <!-- Track header -->
        <div class="flex items-start gap-4 mb-12">
          <div class="w-12 h-12 rounded-xl shrink-0 flex items-center justify-center font-display font-700 text-lg"
               style={`background: ${color}20; border: 1px solid ${color}40; color: ${color}`}>
            {(slug as string).charAt(0).toUpperCase()}
          </div>
          <div>
            <h1 class="font-display text-3xl md:text-4xl font-700 tracking-tight">{track.title}</h1>
            <p class="text-zinc-400 mt-2 text-base">{track.description}</p>
          </div>
        </div>

        {/* If this track has sections, show them with post counts */}
        {sections.length > 0 ? (
          <div class="flex flex-col gap-5">
            {sections.map((section: any) => (
              <a href={`/learn/${slug}/${section.slug}`}
                 class="group block p-6 rounded-xl border border-zinc-800 hover:border-zinc-600 bg-zinc-900/30 hover:bg-zinc-900/60 transition-all">
                <div class="flex items-start justify-between gap-4">
                  <div class="flex-1">
                    <h2 class="font-display text-xl font-600 text-zinc-100 group-hover:text-brand-400 transition-colors mb-1">
                      {section.title}
                    </h2>
                    <p class="text-sm text-zinc-500 leading-relaxed">{section.description}</p>
                  </div>
                  <div class="flex items-center gap-3 shrink-0 mt-1">
                    {section.post_count > 0 && (
                      <span class="text-xs font-mono text-zinc-600">{section.post_count} {section.post_count === 1 ? 'article' : 'articles'}</span>
                    )}
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"
                         class="text-zinc-700 group-hover:text-brand-400 transition-colors">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
                    </svg>
                  </div>
                </div>
              </a>
            ))}
          </div>
        ) : lessons.length > 0 ? (
          /* No sections — show lessons directly */
          <div class="divide-y divide-zinc-800">
            {lessons.map((lesson: any) => (
              <a href={`/learn/${slug}/${lesson.slug}`}
                 class="group flex items-center gap-4 py-5 hover:bg-zinc-900/30 -mx-4 px-4 rounded-lg transition-colors">
                <span class="font-mono text-xs text-zinc-600 w-8 shrink-0">{String(lesson.sort_order).padStart(2,'0')}</span>
                <div class="flex-1">
                  <div class="font-500 text-zinc-100 group-hover:text-brand-400 transition-colors">{lesson.title}</div>
                  <div class="text-sm text-zinc-500 mt-0.5">{lesson.description}</div>
                </div>
                <div class="text-xs text-zinc-600 font-mono">{lesson.read_mins} min</div>
              </a>
            ))}
          </div>
        ) : (
          /* Nothing yet */
          <div class="border border-zinc-800 rounded-xl p-12 text-center">
            <div class="text-zinc-600 text-sm font-mono mb-2">// coming soon</div>
            <p class="text-zinc-500 text-sm">Content is being written. <a href="/#newsletter" class="text-brand-400 hover:text-brand-200 transition-colors">Subscribe to get notified →</a></p>
          </div>
        )}
      </>
    )}
  </div>
</Base>
