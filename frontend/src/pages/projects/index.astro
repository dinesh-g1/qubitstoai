---
import Base from '../../layouts/Base.astro';
const projects = [
  {
    title: 'NAND simulator',
    desc: 'Boolean logic gate simulator built from scratch in Go. Simulate any circuit from NAND primitives.',
    tag: 'Hardware',
    color: '#7F77DD',
    status: 'In progress',
    github: 'https://github.com/qubitstoai/nand-simulator',
  },
  {
    title: 'Mini CPU',
    desc: 'A 16-bit CPU built on breadboard following the nand2tetris curriculum. Runs a small instruction set.',
    tag: 'Hardware',
    color: '#7F77DD',
    status: 'Planned',
    github: '#',
  },
  {
    title: 'qsh — tiny shell',
    desc: 'A POSIX-compatible shell written in C. Supports pipes, redirects, job control, and builtins.',
    tag: 'Systems',
    color: '#1D9E75',
    status: 'Planned',
    github: '#',
  },
  {
    title: 'tinycompiler',
    desc: 'A compiler from a simple language to x86 assembly. Lexer → parser → AST → codegen.',
    tag: 'Compilers',
    color: '#BA7517',
    status: 'Planned',
    github: '#',
  },
  {
    title: 'qubitstoai.com',
    desc: 'This website. Go backend, Astro frontend, PostgreSQL, self-hosted on a VPS. All open source.',
    tag: 'Web',
    color: '#185FA5',
    status: 'Live',
    github: 'https://github.com/qubitstoai/site',
  },
];
---
<Base title="Projects — qubitstoai">
  <div class="max-w-4xl mx-auto px-6 py-16">
    <div class="mb-12">
      <div class="text-xs font-mono text-zinc-500 tracking-widest uppercase mb-3">Open source</div>
      <h1 class="font-display text-4xl md:text-5xl font-700 tracking-tight">Projects</h1>
      <p class="text-zinc-400 text-base mt-3 max-w-lg">Every concept gets built. All repos are public on GitHub.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {projects.map(p => (
        <a href={p.github} target="_blank" rel="noopener noreferrer"
           class="group p-6 rounded-xl border border-zinc-800 hover:border-zinc-600 bg-zinc-900/30 hover:bg-zinc-900/60 transition-all">
          <div class="flex items-start justify-between mb-4">
            <span class="text-xs font-mono px-2 py-0.5 rounded-full border"
                  style={`color: ${p.color}; border-color: ${p.color}40; background: ${p.color}10`}>
              {p.tag}
            </span>
            <span class={`text-xs font-mono ${p.status === 'Live' ? 'text-green-400' : p.status === 'In progress' ? 'text-amber-400' : 'text-zinc-600'}`}>
              {p.status === 'Live' ? '● ' : p.status === 'In progress' ? '◐ ' : '○ '}{p.status}
            </span>
          </div>
          <h3 class="font-display font-600 text-zinc-100 group-hover:text-brand-400 transition-colors mb-2">{p.title}</h3>
          <p class="text-sm text-zinc-500 leading-relaxed">{p.desc}</p>
          <div class="mt-4 flex items-center gap-1 text-xs text-zinc-600 group-hover:text-zinc-400 transition-colors font-mono">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            View on GitHub
          </div>
        </a>
      ))}
    </div>
  </div>
</Base>
