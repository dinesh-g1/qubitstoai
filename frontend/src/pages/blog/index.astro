---
import Base from '../../layouts/Base.astro';
const API = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
let posts: any[] = [];
try {
  const res = await fetch(`${API}/api/v1/posts`);
  if (res.ok) posts = await res.json();
} catch {}
---
<Base title="Blog — qubitstoai">
  <div class="max-w-4xl mx-auto px-6 py-16">
    <div class="mb-12">
      <div class="text-xs font-mono text-zinc-500 tracking-widest uppercase mb-3">Writing</div>
      <h1 class="font-display text-4xl md:text-5xl font-700 tracking-tight">Blog</h1>
      <p class="text-zinc-400 text-base mt-3 max-w-lg">Deep articles on CS fundamentals. Build-logs, explanations, and things I wish existed when I was learning.</p>
    </div>

    {posts.length > 0 ? (
      <div class="divide-y divide-zinc-800">
        {posts.map((post: any, i: number) => (
          <a href={`/blog/${post.slug}`}
             class="group flex items-start gap-6 py-7 hover:bg-zinc-900/30 -mx-4 px-4 rounded-lg transition-colors">
            <span class="font-mono text-xs text-zinc-700 mt-1 w-6 shrink-0">{String(i+1).padStart(2,'0')}</span>
            <div class="flex-1 min-w-0">
              <div class="text-xs font-mono text-brand-400/70 mb-2">{post.tag}</div>
              <h2 class="font-display font-600 text-zinc-100 group-hover:text-brand-400 transition-colors leading-snug text-lg">{post.title}</h2>
              <p class="text-zinc-500 text-sm mt-2 leading-relaxed">{post.description}</p>
              <div class="text-xs text-zinc-600 font-mono mt-3">{post.read_mins} min read</div>
            </div>
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"
                 class="shrink-0 text-zinc-700 group-hover:text-brand-400 transition-colors mt-1">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </a>
        ))}
      </div>
    ) : (
      <div class="border border-dashed border-zinc-800 rounded-xl p-16 text-center">
        <div class="font-mono text-zinc-600 text-sm mb-3">// no posts yet</div>
        <p class="text-zinc-500 text-sm">First articles are being written. <a href="/#newsletter" class="text-brand-400 hover:text-brand-200 transition-colors">Subscribe to be notified →</a></p>
      </div>
    )}
  </div>
</Base>
