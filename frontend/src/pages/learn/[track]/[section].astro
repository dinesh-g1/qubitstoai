---
export const prerender = false;
import Base from '../../../layouts/Base.astro';
const { track: trackSlug, section: sectionSlug } = Astro.params;
const API = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
let track: any = null, section: any = null, posts: any[] = [];
try {
  const [tr, sections, ps] = await Promise.all([
    fetch(`${API}/api/v1/tracks/${trackSlug}`).then(r => r.ok ? r.json() : null),
    fetch(`${API}/api/v1/tracks/${trackSlug}/sections`).then(r => r.ok ? r.json() : []),
    fetch(`${API}/api/v1/tracks/${trackSlug}/sections/${sectionSlug}/posts`).then(r => r.ok ? r.json() : []),
  ]);
  track = tr;
  section = (sections as any[]).find((s: any) => s.slug === sectionSlug) || null;
  posts = ps;
} catch {}
const colors: Record<string,string> = { hardware:'#7C3AED',systems:'#059669',compilers:'#D97706',web:'#2563EB',ml:'#DC2626',agents:'#16A34A' };
const color = colors[trackSlug as string] ?? '#2563EB';
---
<Base title={section ? `${section.title} — qubitstoai` : 'Not found'}>
  <div style="max-width:48rem;margin:0 auto;padding:3.5rem 1.75rem 6rem;">
    {!track || !section ? (
      <div style="text-align:center;padding:4rem 0;"><p style="color:var(--ink-3);">Not found. <a href="/learn">Back to topics →</a></p></div>
    ) : (
      <>
        <div style="display:flex;align-items:center;gap:0.5rem;font-family:var(--font-mono);font-size:var(--text-xs);color:var(--ink-4);margin-bottom:2.5rem;">
          <a href="/learn" style="color:var(--ink-4);text-decoration:none;" onmouseover="this.style.color='var(--blue)'" onmouseout="this.style.color='var(--ink-4)'">Learn</a>
          <span>/</span>
          <a href={`/learn/${trackSlug}`} style="color:var(--ink-4);text-decoration:none;" onmouseover="this.style.color='var(--blue)'" onmouseout="this.style.color='var(--ink-4)'">{track.title}</a>
          <span>/</span>
          <span style="color:var(--ink-2);">{section.title}</span>
        </div>
        <div style="margin-bottom:3rem;">
          <div style={`display:inline-block;font-family:var(--font-mono);font-size:0.7rem;padding:4px 12px;border-radius:999px;margin-bottom:1rem;background:${color}10;color:${color};border:1px solid ${color}20`}>{track.title}</div>
          <h1 style="font-family:var(--font-display);font-size:var(--text-3xl);font-weight:700;color:var(--ink);letter-spacing:-0.02em;margin-bottom:0.5rem;">{section.title}</h1>
          <p style="color:var(--ink-3);font-size:var(--text-base);line-height:1.7;">{section.description}</p>
        </div>
        {posts.length > 0 ? (
          <div>
            {posts.map((post: any, i: number) => (
              <a href={`/blog/${post.slug}`} style="display:flex;align-items:flex-start;gap:1.25rem;padding:1.4rem 1rem;border-bottom:1px solid var(--border-light);border-radius:10px;text-decoration:none;transition:background 0.15s;" onmouseover="this.style.background='var(--bg-raised)'" onmouseout="this.style.background='transparent'">
                <span style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--ink-4);margin-top:4px;width:22px;flex-shrink:0;">{String(i+1).padStart(2,'0')}</span>
                <div style="flex:1;">
                  <div style="font-family:var(--font-display);font-size:1.05rem;font-weight:600;color:var(--ink);line-height:1.35;">{post.title}</div>
                  {post.description && <div style="font-size:var(--text-sm);color:var(--ink-3);margin-top:0.3rem;line-height:1.6;">{post.description}</div>}
                  <div style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--ink-4);margin-top:0.45rem;">{post.read_mins} min read</div>
                </div>
                <svg width="15" height="15" fill="none" stroke="var(--ink-4)" stroke-width="1.5" viewBox="0 0 24 24" style="flex-shrink:0;margin-top:4px;"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              </a>
            ))}
          </div>
        ) : (
          <div style="border:1.5px dashed var(--border);border-radius:12px;padding:3.5rem;text-align:center;">
            <div style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--ink-4);margin-bottom:0.5rem;">// no articles yet</div>
            <p style="color:var(--ink-3);font-size:var(--text-sm);">Articles are being written. <a href="/#newsletter">Subscribe →</a></p>
          </div>
        )}
      </>
    )}
  </div>
</Base>
