---
import Base from '../../layouts/Base.astro';
const API = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
let posts: any[] = [];
try {
  const res = await fetch(`${API}/api/v1/posts`);
  if (res.ok) posts = await res.json();
} catch {}
---
<Base title="Blog — qubitstoai">
  <div style="max-width:48rem;margin:0 auto;padding:3.5rem 1.5rem 6rem;">
    <div style="margin-bottom:2.5rem;">
      <div style="font-family:var(--font-mono);font-size:0.7rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--foreground-4);margin-bottom:0.5rem;">Writing</div>
      <h1 style="font-size:1.75rem;font-weight:700;letter-spacing:-0.02em;color:var(--foreground);margin-bottom:0.5rem;">Blog</h1>
      <p style="font-size:0.875rem;color:var(--foreground-3);max-width:380px;line-height:1.6;">Deep articles on CS fundamentals. Build-logs and things I wish existed when I was learning.</p>
    </div>
    <div style="height:1px;background:var(--border);margin-bottom:1.5rem;"></div>
    {posts.length > 0 ? (
      <div>
        {posts.map((post: any, i: number) => (
          <a href={`/blog/${post.slug}`} style="display:flex;align-items:flex-start;gap:1rem;padding:1rem 0.75rem;border-radius:var(--radius);transition:background 0.1s;text-decoration:none;" onmouseover="this.style.background='var(--background-2)'" onmouseout="this.style.background='transparent'">
            <span style="font-family:var(--font-mono);font-size:0.7rem;color:var(--foreground-4);width:20px;flex-shrink:0;padding-top:3px;">{String(i+1).padStart(2,'0')}</span>
            <div style="flex:1;">
              <div style="font-family:var(--font-mono);font-size:0.65rem;text-transform:uppercase;letter-spacing:0.06em;color:var(--accent);margin-bottom:0.25rem;">{post.tag}</div>
              <div style="font-size:0.9375rem;font-weight:500;color:var(--foreground);line-height:1.4;margin-bottom:0.3rem;">{post.title}</div>
              {post.description && <div style="font-size:0.8125rem;color:var(--foreground-3);line-height:1.5;">{post.description}</div>}
              <div style="font-family:var(--font-mono);font-size:0.7rem;color:var(--foreground-4);margin-top:0.35rem;">{post.read_mins} min read</div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div style="border:1px dashed var(--border);border-radius:var(--radius-lg);padding:3rem;text-align:center;">
        <div style="font-family:var(--font-mono);font-size:0.7rem;color:var(--foreground-4);margin-bottom:0.4rem;">// no posts yet</div>
        <p style="font-size:0.875rem;color:var(--foreground-3);">First articles coming soon. <a href="/#newsletter" style="color:var(--accent);">Subscribe →</a></p>
      </div>
    )}
  </div>
</Base>
