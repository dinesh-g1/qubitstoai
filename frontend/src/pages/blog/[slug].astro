---
export const prerender = false;
import Base from '../../layouts/Base.astro';
const { slug } = Astro.params;
const API = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
let post: any = null;
try {
  const res = await fetch(`${API}/api/v1/posts/${slug}`);
  if (res.ok) post = await res.json();
} catch {}
---
<Base title={post ? `${post.title} — qubitstoai` : 'Post not found'} description={post?.description}>
  {!post ? (
    <div style="max-width:48rem;margin:0 auto;padding:6rem 1.75rem;text-align:center;">
      <div style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--ink-4);margin-bottom:0.5rem;">// 404</div>
      <p style="color:var(--ink-3);">Post not found. <a href="/blog">Back to blog →</a></p>
    </div>
  ) : (
    <div style="max-width:48rem;margin:0 auto;padding:3.5rem 1.75rem 6rem;">
      <a href="/blog" style="display:inline-flex;align-items:center;gap:6px;font-size:var(--text-sm);color:var(--ink-3);margin-bottom:2.5rem;font-weight:500;text-decoration:none;transition:color 0.15s;" onmouseover="this.style.color='var(--blue)'" onmouseout="this.style.color='var(--ink-3)'">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 17l-5-5m0 0l5-5m-5 5h12"/></svg>
        All articles
      </a>
      <header style="margin-bottom:3rem;padding-bottom:2rem;border-bottom:1px solid var(--border);">
        <div style="font-family:var(--font-mono);font-size:0.7rem;color:var(--blue);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:1rem;">{post.tag}</div>
        <h1 style="font-family:var(--font-display);font-size:clamp(1.75rem,4vw,2.75rem);font-weight:700;color:var(--ink);line-height:1.15;letter-spacing:-0.02em;margin-bottom:1rem;">{post.title}</h1>
        {post.description && <p style="font-size:var(--text-lg);color:var(--ink-3);line-height:1.6;">{post.description}</p>}
        <div style="display:flex;align-items:center;gap:1rem;margin-top:1.25rem;font-family:var(--font-mono);font-size:var(--text-xs);color:var(--ink-4);">
          <span>{post.read_mins} min read</span>
          <span>·</span>
          <span>{new Date(post.created_at).toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'})}</span>
        </div>
      </header>
      {post.content ? (
        <article class="prose" set:html={post.content} />
      ) : (
        <div style="border:1.5px dashed var(--border);border-radius:12px;padding:3rem;text-align:center;">
          <div style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--ink-4);margin-bottom:0.5rem;">// content coming soon</div>
          <p style="color:var(--ink-3);font-size:var(--text-sm);">Full article is being written.</p>
        </div>
      )}
    </div>
  )}
</Base>
