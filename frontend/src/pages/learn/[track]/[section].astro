---
export const prerender = false;
import Base from '../../../layouts/Base.astro';
const { track: trackSlug, section: sectionSlug } = Astro.params;
const API = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
let track: any = null, section: any = null, posts: any[] = [];
try {
  const [tr, sections, ps] = await Promise.all([
    fetch(`${API}/api/v1/tracks/${trackSlug}`).then(r => r.ok ? r.json() : null),
    fetch(`${API}/api/v1/tracks/${trackSlug}/sections`).then(r => r.ok ? r.json() : []),
    fetch(`${API}/api/v1/tracks/${trackSlug}/sections/${sectionSlug}/posts`).then(r => r.ok ? r.json() : []),
  ]);
  track = tr;
  section = (sections as any[]).find((s: any) => s.slug === sectionSlug) || null;
  posts = ps;
} catch {}
const colors: Record<string,string> = {
  hardware:'var(--c-hardware)',systems:'var(--c-systems)',compilers:'var(--c-compilers)',
  web:'var(--c-web)',ml:'var(--c-ml)',agents:'var(--c-agents)'
};
const color = colors[trackSlug as string] ?? 'var(--accent)';
---
<Base title={section ? `${section.title} — qubitstoai` : 'Not found'}>
  <div style="max-width:48rem;margin:0 auto;padding:3rem 1.5rem 6rem;">
    {!track || !section ? (
      <p style="color:var(--foreground-3);font-size:0.875rem;">Not found. <a href="/learn" style="color:var(--accent);">← Back</a></p>
    ) : (
      <>
        <div style="display:flex;align-items:center;gap:0.5rem;font-family:var(--font-mono);font-size:0.7rem;color:var(--foreground-4);margin-bottom:2rem;">
          <a href="/learn" style="color:var(--foreground-4);transition:color 0.1s;" onmouseover="this.style.color='var(--foreground)'" onmouseout="this.style.color='var(--foreground-4)'">Learn</a>
          <span>/</span>
          <a href={`/learn/${trackSlug}`} style="color:var(--foreground-4);transition:color 0.1s;" onmouseover="this.style.color='var(--foreground)'" onmouseout="this.style.color='var(--foreground-4)'">{track.title}</a>
          <span>/</span>
          <span style="color:var(--foreground-3);">{section.title}</span>
        </div>
        <div style="margin-bottom:2.5rem;padding-bottom:1.75rem;border-bottom:1px solid var(--border);">
          <div style="margin-bottom:0.75rem;">
            <span style={`font-family:var(--font-mono);font-size:0.65rem;padding:2px 8px;border-radius:var(--radius-sm);background:color-mix(in srgb,${color} 12%,var(--background-2));color:${color}`}>{track.title}</span>
          </div>
          <h1 style="font-size:1.5rem;font-weight:700;letter-spacing:-0.02em;color:var(--foreground);margin-bottom:0.4rem;">{section.title}</h1>
          <p style="font-size:0.875rem;color:var(--foreground-3);line-height:1.6;">{section.description}</p>
        </div>
        {posts.length > 0 ? (
          <div>
            {posts.map((post: any, i: number) => (
              <a href={`/blog/${post.slug}`} style="display:flex;align-items:flex-start;gap:1rem;padding:1rem 0.75rem;border-radius:var(--radius);transition:background 0.1s;text-decoration:none;" onmouseover="this.style.background='var(--background-2)'" onmouseout="this.style.background='transparent'">
                <span style="font-family:var(--font-mono);font-size:0.7rem;color:var(--foreground-4);width:20px;flex-shrink:0;padding-top:3px;">{String(i+1).padStart(2,'0')}</span>
                <div style="flex:1;">
                  <div style="font-size:0.9375rem;font-weight:500;color:var(--foreground);line-height:1.4;margin-bottom:0.3rem;">{post.title}</div>
                  {post.description && <div style="font-size:0.8rem;color:var(--foreground-3);line-height:1.5;">{post.description}</div>}
                  <div style="font-family:var(--font-mono);font-size:0.7rem;color:var(--foreground-4);margin-top:0.35rem;">{post.read_mins} min read</div>
                </div>
                <svg width="14" height="14" fill="none" stroke="var(--foreground-4)" stroke-width="1.5" viewBox="0 0 24 24" style="flex-shrink:0;margin-top:3px;"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              </a>
            ))}
          </div>
        ) : (
          <div style="border:1px dashed var(--border);border-radius:var(--radius-lg);padding:3rem;text-align:center;">
            <div style="font-family:var(--font-mono);font-size:0.7rem;color:var(--foreground-4);margin-bottom:0.4rem;">// no articles yet</div>
            <p style="font-size:0.875rem;color:var(--foreground-3);">Articles being written. <a href="/#newsletter" style="color:var(--accent);">Subscribe →</a></p>
          </div>
        )}
      </>
    )}
  </div>
</Base>
