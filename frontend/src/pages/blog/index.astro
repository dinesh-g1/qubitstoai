---
import Base from '../../layouts/Base.astro';
const API = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
let posts: any[] = [];
try { const r = await fetch(`${API}/api/v1/posts`); if (r.ok) posts = await r.json(); } catch {}
---
<Base title="Blog — qubitstoai">
<div style="max-width:48rem;margin:0 auto;padding:3rem 1.5rem 6rem;">
  <div style="padding-bottom:1.5rem;border-bottom:1px solid var(--border);margin-bottom:1.25rem;">
    <div style="font-size:0.6rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--fg-4);margin-bottom:0.3rem;">writing</div>
    <h1 style="font-size:1.5rem;font-weight:700;letter-spacing:-0.02em;color:var(--fg);">Blog</h1>
    <p style="font-size:0.75rem;color:var(--fg-3);margin-top:0.35rem;max-width:340px;line-height:1.65;">Deep articles on CS fundamentals. Build-logs and things I wish existed when I was learning.</p>
  </div>
  {posts.length > 0 ? (
    <div>
      {posts.map((p: any, i: number) => (
        <a href={`/blog/${p.slug}`} style="display:flex;align-items:flex-start;gap:0.875rem;padding:0.75rem 0.625rem;transition:background 0.1s;text-decoration:none;" onmouseover="this.style.background='var(--bg-hover)'" onmouseout="this.style.background='transparent'">
          <span style="font-size:0.6rem;color:var(--fg-4);width:16px;flex-shrink:0;padding-top:2px;">{String(i+1).padStart(2,'0')}</span>
          <div style="flex:1;">
            <div style="font-size:0.6rem;text-transform:uppercase;letter-spacing:0.06em;color:var(--fg-4);margin-bottom:0.15rem;">{p.tag}</div>
            <div style="font-size:0.8125rem;font-weight:500;color:var(--fg);line-height:1.4;">{p.title}</div>
            {p.description && <div style="font-size:0.72rem;color:var(--fg-3);margin-top:0.2rem;line-height:1.5;">{p.description}</div>}
            <div style="font-size:0.6rem;color:var(--fg-4);margin-top:0.3rem;">{p.read_mins} min read</div>
          </div>
        </a>
      ))}
    </div>
  ) : (
    <div style="padding:2.5rem;border:1px dashed var(--border);text-align:center;">
      <div style="font-size:0.65rem;color:var(--fg-4);margin-bottom:0.35rem;">// no posts yet</div>
      <p style="font-size:0.75rem;color:var(--fg-3);">First articles coming soon. <a href="/#newsletter" style="color:var(--fg);text-decoration:underline;text-underline-offset:3px;">subscribe →</a></p>
    </div>
  )}
</div>
</Base>
