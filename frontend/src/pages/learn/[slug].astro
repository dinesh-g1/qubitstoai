---
export const prerender = false;
import Base from '../../layouts/Base.astro';
const slug = Astro.params.slug;
const API = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
let track: any = null, sections: any[] = [], lessons: any[] = [];
try {
  const [tr,sc,ls] = await Promise.all([
    fetch(`${API}/api/v1/tracks/${slug}`).then(r=>r.ok?r.json():null),
    fetch(`${API}/api/v1/tracks/${slug}/sections`).then(r=>r.ok?r.json():[]),
    fetch(`${API}/api/v1/tracks/${slug}/lessons`).then(r=>r.ok?r.json():[]),
  ]);
  track=tr; sections=sc; lessons=ls;
} catch {}
const dots: Record<string,string> = {hardware:'var(--c-hw)',systems:'var(--c-sy)',compilers:'var(--c-co)',web:'var(--c-wb)',ml:'var(--c-ml)',agents:'var(--c-ag)'};
const dot = dots[slug as string] ?? 'var(--fg-3)';
---
<Base title={track ? `${track.title} — qubitstoai` : 'Not found'}>
<div style="max-width:52rem;margin:0 auto;padding:3rem 1.5rem 6rem;">
  {!track ? (
    <p style="font-size:0.8125rem;color:var(--fg-3);">not found. <a href="/learn" style="color:var(--fg);text-decoration:underline;">← back</a></p>
  ) : (
    <>
      <a href="/learn" style="display:inline-flex;align-items:center;gap:5px;font-size:0.7rem;color:var(--fg-4);margin-bottom:2rem;transition:color 0.1s;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--fg-4)'">
        <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 17l-5-5m0 0l5-5m-5 5h12"/></svg>
        all topics
      </a>
      <div style="display:flex;align-items:flex-start;gap:0.875rem;padding-bottom:1.5rem;border-bottom:1px solid var(--border);margin-bottom:1.5rem;">
        <span style={`width:8px;height:8px;border-radius:50%;background:${dot};flex-shrink:0;margin-top:6px;`}></span>
        <div>
          <h1 style="font-size:1.25rem;font-weight:700;letter-spacing:-0.02em;color:var(--fg);margin-bottom:0.25rem;">{track.title}</h1>
          <p style="font-size:0.75rem;color:var(--fg-3);">{track.description}</p>
        </div>
      </div>
      {sections.length > 0 ? (
        <div style="display:flex;flex-direction:column;gap:0.375rem;">
          {sections.map((s: any) => (
            <a href={`/learn/${slug}/${s.slug}`} style="display:flex;align-items:center;justify-content:space-between;gap:1rem;padding:1rem 1.125rem;border:1px solid var(--border);background:var(--bg-card);transition:background 0.1s;text-decoration:none;" onmouseover="this.style.background='var(--bg-hover)'" onmouseout="this.style.background='var(--bg-card)'">
              <div>
                <div style="font-size:0.8125rem;font-weight:600;color:var(--fg);margin-bottom:0.2rem;">{s.title}</div>
                <div style="font-size:0.7rem;color:var(--fg-4);line-height:1.5;">{s.description}</div>
              </div>
              <div style="display:flex;align-items:center;gap:0.625rem;flex-shrink:0;">
                {s.post_count > 0 && <span style="font-size:0.6rem;color:var(--fg-4);">{s.post_count} article{s.post_count!==1?'s':''}</span>}
                <svg width="12" height="12" fill="none" stroke="var(--fg-4)" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
              </div>
            </a>
          ))}
        </div>
      ) : lessons.length > 0 ? (
        <div>
          {lessons.map((l: any) => (
            <a href={`/learn/${slug}/${l.slug}`} style="display:flex;align-items:center;gap:0.875rem;padding:0.75rem 0.625rem;transition:background 0.1s;text-decoration:none;" onmouseover="this.style.background='var(--bg-hover)'" onmouseout="this.style.background='transparent'">
              <span style="font-size:0.6rem;color:var(--fg-4);width:20px;flex-shrink:0;">{String(l.sort_order).padStart(2,'0')}</span>
              <div style="flex:1;">
                <div style="font-size:0.8125rem;font-weight:500;color:var(--fg);">{l.title}</div>
                <div style="font-size:0.7rem;color:var(--fg-4);margin-top:0.15rem;">{l.description}</div>
              </div>
              <span style="font-size:0.6rem;color:var(--fg-4);">{l.read_mins}m</span>
            </a>
          ))}
        </div>
      ) : (
        <div style="padding:2.5rem;border:1px dashed var(--border);text-align:center;">
          <div style="font-size:0.65rem;color:var(--fg-4);margin-bottom:0.35rem;">// coming soon</div>
          <p style="font-size:0.75rem;color:var(--fg-3);">content is being written. <a href="/#newsletter" style="color:var(--fg);text-decoration:underline;">subscribe →</a></p>
        </div>
      )}
    </>
  )}
</div>
</Base>
