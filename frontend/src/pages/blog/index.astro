---
import Base from '../../layouts/Base.astro';
const API = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';
let posts: any[] = [];
try {
  const res = await fetch(`${API}/api/v1/posts`);
  if (res.ok) posts = await res.json();
} catch {}
---
<Base title="Blog — qubitstoai">
  <div style="max-width:48rem;margin:0 auto;padding:4rem 1.75rem 6rem;">
    <div style="margin-bottom:3rem;">
      <div class="label" style="margin-bottom:0.6rem;">Writing</div>
      <h1 style="font-family:var(--font-display);font-size:var(--text-4xl);font-weight:700;color:var(--ink);letter-spacing:-0.02em;margin-bottom:0.75rem;">Blog</h1>
      <p style="color:var(--ink-3);font-size:var(--text-base);max-width:400px;line-height:1.7;">Deep articles on CS fundamentals. Explanations, build-logs, and things I wish existed when I was learning.</p>
    </div>
    {posts.length > 0 ? (
      <div>
        {posts.map((post: any, i: number) => (
          <a href={`/blog/${post.slug}`} style="display:flex;align-items:flex-start;gap:1.25rem;padding:1.4rem 1rem;border-bottom:1px solid var(--border-light);border-radius:10px;text-decoration:none;transition:background 0.15s;" onmouseover="this.style.background='var(--bg-raised)'" onmouseout="this.style.background='transparent'">
            <span style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--ink-4);margin-top:4px;width:22px;flex-shrink:0;">{String(i+1).padStart(2,'0')}</span>
            <div style="flex:1;">
              <div style="font-family:var(--font-mono);font-size:0.7rem;color:var(--blue);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.3rem;">{post.tag}</div>
              <div style="font-family:var(--font-display);font-size:1.1rem;font-weight:600;color:var(--ink);line-height:1.35;margin-bottom:0.35rem;">{post.title}</div>
              {post.description && <div style="font-size:var(--text-sm);color:var(--ink-3);line-height:1.6;">{post.description}</div>}
              <div style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--ink-4);margin-top:0.5rem;">{post.read_mins} min read</div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div style="border:1.5px dashed var(--border);border-radius:12px;padding:4rem;text-align:center;">
        <div style="font-family:var(--font-mono);font-size:var(--text-xs);color:var(--ink-4);margin-bottom:0.5rem;">// no posts yet</div>
        <p style="color:var(--ink-3);font-size:var(--text-sm);">First articles are being written. <a href="/#newsletter">Subscribe to get notified →</a></p>
      </div>
    )}
  </div>
</Base>
