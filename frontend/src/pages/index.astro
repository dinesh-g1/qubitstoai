---
import Base from '../layouts/Base.astro';

const API = import.meta.env.PUBLIC_API_URL || 'http://localhost:8080';

const tracks = [
  { slug:'hardware',  title:'Hardware',          sub:'NAND gates → CPU',        color:'#7F77DD', icon:'⬡' },
  { slug:'systems',   title:'Systems',            sub:'Assembly → OS internals', color:'#1D9E75', icon:'⬡' },
  { slug:'compilers', title:'Compilers & VMs',    sub:'Lexers → bytecode',       color:'#BA7517', icon:'⬡' },
  { slug:'web',       title:'Web & Backend',      sub:'HTTP → full-stack apps',  color:'#185FA5', icon:'⬡' },
  { slug:'ml',        title:'ML & Deep Learning', sub:'Math → transformers',     color:'#993C1D', icon:'⬡' },
  { slug:'agents',    title:'AI Agents',          sub:'Planning → autonomy',     color:'#3B6D11', icon:'⬡' },
];

let posts = [];
try {
  const res = await fetch(`${API}/api/v1/posts`);
  if (res.ok) posts = await res.json();
} catch {}
---
<Base>
  <!-- ── HERO ─────────────────────────────────────────────────────────────── -->
  <section class="relative min-h-[92vh] flex flex-col justify-center px-6 overflow-hidden">

    <!-- Background grid -->
    <div class="absolute inset-0 opacity-[0.04]"
         style="background-image: linear-gradient(#7F77DD 1px, transparent 1px), linear-gradient(90deg, #7F77DD 1px, transparent 1px); background-size: 60px 60px;">
    </div>

    <!-- Glow orb -->
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[600px] h-[300px] rounded-full opacity-10"
         style="background: radial-gradient(ellipse, #7F77DD 0%, transparent 70%); filter: blur(60px);">
    </div>

    <div class="relative max-w-6xl mx-auto w-full">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 text-xs text-brand-400 border border-brand-400/30 rounded-full px-3 py-1 mb-8 font-mono">
        <span class="w-1.5 h-1.5 rounded-full bg-brand-400 animate-pulse"></span>
        Building in public · learning out of curiosity
      </div>

      <!-- Headline -->
      <h1 class="font-display text-5xl md:text-7xl font-800 leading-[0.95] tracking-tight mb-6 max-w-3xl">
        Computer<br/>
        science<br/>
        <span class="text-brand-400">ground up.</span>
      </h1>

      <p class="text-zinc-400 text-lg md:text-xl leading-relaxed max-w-xl mb-10">
        From a single NAND gate to autonomous AI agents. Every layer explained, every concept built from scratch.
      </p>

      <div class="flex flex-wrap gap-4">
        <a href="/learn" class="inline-flex items-center gap-2 px-6 py-3 bg-brand-400 hover:bg-brand-600 text-white rounded-lg font-500 text-sm transition-colors">
          Start learning
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </a>
        <a href="/blog" class="inline-flex items-center gap-2 px-6 py-3 border border-zinc-700 hover:border-zinc-500 text-zinc-300 rounded-lg font-500 text-sm transition-colors">
          Read the blog
        </a>
      </div>

      <!-- Stats row -->
      <div class="flex flex-wrap gap-8 mt-16 pt-8 border-t border-zinc-800/60 text-sm">
        <div><span class="text-2xl font-display font-700 text-zinc-100">6</span><span class="text-zinc-500 ml-2">tracks</span></div>
        <div><span class="text-2xl font-display font-700 text-zinc-100">120+</span><span class="text-zinc-500 ml-2">planned lessons</span></div>
        
        <div><span class="text-2xl font-display font-700 text-brand-400">Free</span><span class="text-zinc-500 ml-2">forever</span></div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-zinc-600 text-xs animate-bounce">
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>
  </section>

  <!-- ── TRACKS ─────────────────────────────────────────────────────────── -->
  <section class="px-6 py-24 max-w-6xl mx-auto">
    <div class="mb-12">
      <div class="text-xs font-mono text-zinc-500 tracking-widest uppercase mb-3">Exploring</div>
      <h2 class="font-display text-3xl md:text-4xl font-700 tracking-tight">Topics I'm diving into</h2>
      <p class="text-zinc-400 mt-3 text-base max-w-lg">From hardware to AI — explored in whatever order curiosity takes me.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {tracks.map((track, i) => (
        <a href={`/learn/${track.slug}`}
           class="group relative p-6 rounded-xl border border-zinc-800 hover:border-zinc-600 bg-zinc-900/40 hover:bg-zinc-900/80 transition-all duration-200">
          <div class="flex items-start justify-between mb-4">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center text-lg"
                 style={`background: ${track.color}20; border: 1px solid ${track.color}40`}>
              <span style={`color: ${track.color}`}>{i + 1}</span>
            </div>
            
          </div>
          <h3 class="font-display font-600 text-zinc-100 mb-1 group-hover:text-brand-400 transition-colors">{track.title}</h3>
          <p class="text-sm text-zinc-500">{track.sub}</p>
          <div class="mt-4 flex items-center gap-1 text-xs text-zinc-600 group-hover:text-zinc-400 transition-colors">
            <span>View track</span>
            <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ── LATEST POSTS ───────────────────────────────────────────────────── -->
  <section class="px-6 pb-24 max-w-6xl mx-auto">
    <div class="flex items-end justify-between mb-10">
      <div>
        <div class="text-xs font-mono text-zinc-500 tracking-widest uppercase mb-3">Latest</div>
        <h2 class="font-display text-3xl md:text-4xl font-700 tracking-tight">Recent articles</h2>
      </div>
      <a href="/blog" class="text-sm text-brand-400 hover:text-brand-200 transition-colors hidden md:block">All articles →</a>
    </div>

    {posts.length > 0 ? (
      <div class="divide-y divide-zinc-800">
        {posts.slice(0,5).map((post: any, i: number) => (
          <a href={`/blog/${post.slug}`}
             class="group flex items-start gap-6 py-6 hover:bg-zinc-900/30 -mx-4 px-4 rounded-lg transition-colors">
            <span class="font-mono text-xs text-zinc-700 mt-1 w-6 shrink-0">{String(i+1).padStart(2,'0')}</span>
            <div class="flex-1 min-w-0">
              <div class="text-xs font-mono text-brand-400/80 mb-1">{post.tag}</div>
              <div class="font-500 text-zinc-100 group-hover:text-brand-400 transition-colors leading-snug">{post.title}</div>
              <div class="text-sm text-zinc-500 mt-1">{post.read_mins} min read</div>
            </div>
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"
                 class="shrink-0 text-zinc-700 group-hover:text-brand-400 transition-colors mt-1">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
            </svg>
          </a>
        ))}
      </div>
    ) : (
      <div class="border border-zinc-800 rounded-xl p-12 text-center">
        <div class="text-zinc-600 text-sm font-mono mb-2">// coming soon</div>
        <p class="text-zinc-500 text-sm">First articles dropping soon. Subscribe to be notified.</p>
      </div>
    )}
  </section>

  <!-- ── NEWSLETTER ─────────────────────────────────────────────────────── -->
  <section id="newsletter" class="px-6 py-24 border-t border-zinc-800">
    <div class="max-w-2xl mx-auto text-center">
      <div class="text-xs font-mono text-zinc-500 tracking-widest uppercase mb-4">Newsletter</div>
      <h2 class="font-display text-3xl md:text-4xl font-700 tracking-tight mb-4">Follow the build</h2>
      <p class="text-zinc-400 text-base leading-relaxed mb-8">
        Weekly dispatch: what I learned, what I built, what broke. No spam. Unsubscribe anytime.
      </p>
      <form id="nl-form" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <input type="email" id="nl-email" placeholder="you@email.com" required
               class="flex-1 px-4 py-2.5 bg-zinc-900 border border-zinc-700 focus:border-brand-400 rounded-lg text-sm text-zinc-100 placeholder-zinc-600 outline-none transition-colors" />
        <button type="submit"
                class="px-6 py-2.5 bg-brand-400 hover:bg-brand-600 text-white rounded-lg text-sm font-500 transition-colors whitespace-nowrap">
          Subscribe →
        </button>
      </form>
      <p id="nl-msg" class="mt-3 text-sm text-zinc-500 hidden"></p>
    </div>
  </section>
</Base>

<script>
  const form = document.getElementById('nl-form') as HTMLFormElement;
  const msg  = document.getElementById('nl-msg') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (document.getElementById('nl-email') as HTMLInputElement).value;
    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      msg.textContent = res.ok ? 'Subscribed! Talk soon.' : 'Something went wrong — try again.';
      msg.classList.remove('hidden', 'text-red-400');
      msg.classList.add(res.ok ? 'text-brand-400' : 'text-red-400');
      if (res.ok) form.reset();
    } catch {
      msg.textContent = 'Network error — try again.';
      msg.classList.remove('hidden');
    }
  });
</script>
